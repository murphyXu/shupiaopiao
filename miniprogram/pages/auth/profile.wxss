.page { padding: 24rpx 24rpx 60rpx; }
.avatar-btn { background: none; border: none; display: flex; flex-direction: column; align-items: center; }
.avatar { width: 120rpx; height: 120rpx; border-radius: 50%; margin-bottom: 12rpx; }
.label { font-size: 26rpx; color: #9aa8a0; margin-bottom: 12rpx; }
.label.strong { color: #15211B; font-weight: 800; margin-bottom: 4rpx; }
.chips { display: flex; flex-wrap: wrap; }
.address-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}
.hint {
  font-size: 22rpx;
}
.mini-link {
  flex-shrink: 0;
  color: #0C7A4B;
  background: #EAFBF2;
  border-radius: 20rpx;
  padding: 10rpx 16rpx;
  font-size: 22rpx;
  font-weight: 700;
}
.field .form-label {
  margin-bottom: 8rpx;
}
