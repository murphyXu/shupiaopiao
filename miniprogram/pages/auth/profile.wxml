<view class="page">
  <view class="card user-id-card">
    <view class="label">用户 ID</view>
    <view class="user-id-row">
      <text class="user-id-text" selectable>{{userId}}</text>
      <view class="copy-id-btn" bindtap="copyUserId">复制 ID</view>
    </view>
  </view>

  <view class="card">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="avatar" src="{{avatar || '/assets/icons/mine.png'}}" mode="aspectFill" />
      <text class="muted">点击设置头像</text>
    </button>
  </view>

  <view class="card">
    <view class="form-label">昵称</view>
    <input class="form-control" type="nickname" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNickname" />
  </view>

  <view class="card">
    <view class="label">孩子年龄段（选填）</view>
    <view class="chips">
      <view wx:for="{{ageRanges}}" wx:key="key" class="chip {{childAgeRange === item.key ? 'active' : ''}}" data-key="{{item.key}}" bindtap="selectAge">{{item.label}}</view>
    </view>
  </view>

  <view class="card address-card">
    <view class="section-head">
      <view>
        <view class="label strong">收货地址</view>
        <view class="muted hint">用于领取漂流图书，可在这里维护默认地址</view>
      </view>
      <view class="mini-link" bindtap="chooseWxAddress">读取微信地址</view>
    </view>
    <view class="field">
      <view class="form-label">收货人</view>
      <input class="form-control" placeholder="姓名" value="{{addressName}}" bindinput="onAddressName" />
    </view>
    <view class="field">
      <view class="form-label">手机号</view>
      <input class="form-control" type="number" placeholder="手机号" value="{{addressPhone}}" bindinput="onAddressPhone" />
    </view>
    <view class="field">
      <view class="form-label">省市区</view>
      <input class="form-control" placeholder="如：上海市浦东新区" value="{{addressRegion}}" bindinput="onAddressRegion" />
    </view>
    <view class="field">
      <view class="form-label">详细地址</view>
      <textarea class="form-textarea" placeholder="街道门牌号" value="{{addressDetail}}" bindinput="onAddressDetail" />
    </view>
  </view>

  <view class="btn-primary" bindtap="save">保存</view>
</view>
