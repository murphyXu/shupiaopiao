.balance-card {
  margin-bottom: 32rpx;
}

.wallet-hero-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-muted {
  color: #fff;
  opacity: 0.88;
}

.hero-formula {
  display: inline-block;
  margin-top: 16rpx;
  padding: 8rpx 16rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #fff;
  font-size: 22rpx;
  opacity: 0.92;
}

.howto-card {
  background: #edf8f2;
  border: 1rpx solid #dcefe4;
}

.howto-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #0C7A4B;
  margin-bottom: 14rpx;
}

.howto-line {
  position: relative;
  padding-left: 26rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: #46564e;
}

.howto-line::before {
  content: "";
  position: absolute;
  left: 6rpx;
  top: 18rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #2FBE77;
}

.wallet-earn-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
  min-width: 132rpx;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  background: #fff;
  color: #0C7A4B;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
  box-shadow: 0 8rpx 18rpx rgba(12, 122, 75, 0.16);
}

.tx-item .row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.desc {
  font-size: 28rpx;
  font-weight: 500;
  color: #15211B;
}

.amount.plus {
  color: #0C7A4B;
  font-weight: 700;
  font-size: 30rpx;
}

.amount.minus {
  color: #ff4d4f;
  font-weight: 700;
  font-size: 30rpx;
}

.amount.neutral {
  color: #52675c;
  font-weight: 700;
  font-size: 30rpx;
}

.time {
  font-size: 22rpx;
  margin-top: 6rpx;
}
