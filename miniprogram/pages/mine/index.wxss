.card-flat {
  background: transparent;
  border: none;
  box-shadow: none;
  padding: 0 0 24rpx;
  margin-bottom: 8rpx;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.user-row .avatar-placeholder {
  width: 104rpx;
  height: 104rpx;
}

.user-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.info {
  flex: 1;
  min-width: 0;
}

.name-line {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.name {
  font-size: 34rpx;
  font-weight: 700;
  color: #15211B;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.edit-profile {
  flex-shrink: 0;
  color: #52605a;
  background: transparent;
  border-radius: 0;
  padding: 0;
  font-size: 24rpx;
  font-weight: 600;
}

.mine-stat-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.mine-stat-card {
  min-width: 0;
  border: 1rpx solid #e7eee9;
  border-radius: 30rpx;
  padding: 36rpx 20rpx;
  background: #ffffff;
  color: #0C7A4B;
  text-align: center;
  line-height: 1.35;
  box-shadow: 0 16rpx 48rpx rgba(21, 158, 99, 0.06);
  box-sizing: border-box;
}

.mine-stat-card::after {
  border: none;
}

.mine-stat-card-hover {
  opacity: 0.86;
  transform: scale(0.98);
}

.stat-num {
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.05;
  letter-spacing: 0.5rpx;
}

.stat-label {
  margin-top: 10rpx;
  color: #159E63;
  font-size: 24rpx;
  font-weight: 700;
}

.stat-tip {
  margin-top: 6rpx;
  color: #8a988f;
  font-size: 22rpx;
}

.menu-item-label {
  flex: 1;
  min-width: 0;
}

.menu-item-trail {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.menu-sub {
  margin-top: 8rpx;
  color: #7b8a82;
  font-size: 22rpx;
  line-height: 1.45;
}

.todo-badges {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8rpx;
  max-width: 360rpx;
}

.todo-badge {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f7ef;
  color: #0C7A4B;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.4;
  white-space: nowrap;
}

.invite-block {
  margin-top: 24rpx;
  padding: 28rpx 28rpx;
}

.invite-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.invite-title {
  color: #15211B;
  font-size: 28rpx;
  font-weight: 800;
}

.invite-share-btn {
  flex-shrink: 0;
  margin: 0;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 30rpx;
  border-radius: 28rpx;
  background: #2FBE77;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.invite-share-btn::after {
  border: none;
}

.invite-desc {
  margin-top: 16rpx;
  color: #7b8a82;
  font-size: 23rpx;
  line-height: 1.6;
}

.invite-reward {
  margin-top: 12rpx;
  color: #4f6b5d;
  font-size: 21rpx;
  line-height: 1.4;
  white-space: nowrap;
}

.guest-login-tag {
  background: #fff;
  border: 1rpx solid #c8e8d8;
}

.invite-share-placeholder {
  display: inline-block;
  text-align: center;
  box-sizing: border-box;
}

.oa-mine-card {
  margin-top: 24rpx;
  padding: 0;
}

.oa-mine-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 28rpx;
  font-size: 28rpx;
  color: #15211B;
}

.oa-mine-item-hover {
  opacity: 0.82;
}

.oa-mine-title {
  font-weight: 600;
}
