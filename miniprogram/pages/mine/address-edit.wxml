<view class="page">
  <view class="card form-card">
    <view class="form-field">
      <view class="form-label">收货人</view>
      <input class="form-control" placeholder="姓名" value="{{name}}" bindinput="onName" />
    </view>
    <view class="form-field">
      <view class="form-label">手机号</view>
      <input class="form-control" type="number" placeholder="手机号" value="{{phone}}" bindinput="onPhone" />
    </view>
    <view class="form-field">
      <view class="form-label">省市区</view>
      <input class="form-control" placeholder="如：上海市浦东新区" value="{{region}}" bindinput="onRegion" />
    </view>
    <view class="form-field">
      <view class="form-label">详细地址</view>
      <textarea class="form-textarea" placeholder="街道门牌号" value="{{detail}}" bindinput="onDetail" />
    </view>
  </view>
  <view class="card">
    <switch checked="{{isDefault}}" bindchange="onDefault" color="#2FBE77" /> 设为默认地址
  </view>
  <view class="btn-primary" bindtap="save">保存</view>
</view>
