<view class="page page-tab" style="padding-top: {{navPaddingTop}}px;">
  <custom-nav-bar title="我的" />
  <view class="user-row card-flat" bindtap="{{loggedIn ? 'goProfile' : 'goLogin'}}" hover-class="{{loggedIn ? 'user-row-hover' : ''}}">
    <image wx:if="{{loggedIn && user.avatar}}" class="user-avatar" src="{{user.avatar}}" mode="aspectFill" />
    <image wx:else class="avatar-placeholder" src="/assets/brand/logo.png" mode="aspectFit" />
    <view class="info">
      <view class="name-line">
        <view class="name">{{loggedIn ? (user.nickname || '书漂用户') : '未登录'}}</view>
        <view wx:if="{{loggedIn}}" class="edit-profile">编辑资料</view>
        <view wx:else class="edit-profile guest-login-tag">去登录</view>
      </view>
    </view>
  </view>

  <view class="mine-stat-row">
    <view class="mine-stat-card public-points-card" hover-class="mine-stat-card-hover" bindtap="goWallet">
      <view class="stat-num">{{loggedIn ? user.availableCoin : '--'}}</view>
      <view class="stat-label">公益积分</view>
      <view class="stat-tip">{{loggedIn ? '站内流转' : '登录后查看'}}</view>
    </view>
    <view class="mine-stat-card credit-stat-card" hover-class="mine-stat-card-hover" bindtap="goCredit">
      <view class="stat-num">{{loggedIn ? user.creditScore : '--'}}</view>
      <view class="stat-label">信用积分</view>
      <view class="stat-tip">{{loggedIn ? '查看明细' : '登录后查看'}}</view>
    </view>
  </view>

  <view class="card mine-menu-card">
    <view class="mine-menu-title">漂流记录</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goGiven">
        <view class="menu-item-label">
          <view>我送出的书</view>
          <view wx:if="{{!loggedIn}}" class="menu-sub">登录后查看送出的书</view>
        </view>
        <view class="menu-item-trail">
          <view wx:if="{{loggedIn && givenBadges.length}}" class="todo-badges">
            <view wx:for="{{givenBadges}}" wx:key="label" class="todo-badge">{{item.label}} {{item.count}}</view>
          </view>
          <text class="menu-arrow">›</text>
        </view>
      </view>
      <view class="menu-item" bindtap="goReceived">
        <view class="menu-item-label">
          <view>我接到的书</view>
          <view wx:if="{{!loggedIn}}" class="menu-sub">登录后查看接到的书</view>
        </view>
        <view class="menu-item-trail">
          <view wx:if="{{loggedIn && receivedBadges.length}}" class="todo-badges">
            <view wx:for="{{receivedBadges}}" wx:key="label" class="todo-badge">{{item.label}} {{item.count}}</view>
          </view>
          <text class="menu-arrow">›</text>
        </view>
      </view>
      <view class="menu-item" bindtap="goWants">
        <view class="menu-item-label">
          <view>我想要的书</view>
          <view wx:if="{{!loggedIn}}" class="menu-sub">登录后查看想要接漂的书</view>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="card mine-menu-card">
    <view class="mine-menu-title">积分规则</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goWallet">公益积分明细<text class="menu-arrow">›</text></view>
      <view class="menu-item" bindtap="goCredit">信用积分明细<text class="menu-arrow">›</text></view>
      <view class="menu-item" bindtap="goSettings">隐私政策 / 设置<text class="menu-arrow">›</text></view>
    </view>
  </view>

  <view wx:if="{{loggedIn && user.isAdmin}}" class="card mine-menu-card">
    <view class="menu-list">
      <view class="menu-item" bindtap="goDisputes">申诉处理<text class="menu-arrow">›</text></view>
      <view class="menu-item" bindtap="goDashboard">数据看板<text class="menu-arrow">›</text></view>
    </view>
  </view>

  <view wx:if="{{showOaMineCard}}" class="card oa-mine-card">
    <view class="oa-mine-item" hover-class="oa-mine-item-hover" bindtap="openOaProfile">
      <view class="oa-mine-title">书漂漂公众号</view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="card invite-block">
    <image class="share-cover-preload" src="/assets/share/share-cover.jpg" />
    <view class="invite-head">
      <view class="invite-title">邀请书友共建</view>
      <button wx:if="{{loggedIn}}" class="invite-share-btn" open-type="share">邀请</button>
      <view wx:else class="invite-share-btn invite-share-placeholder" bindtap="goLogin">登录后邀请</view>
    </view>
    <view class="invite-desc">书架闲置清出去，童书绘本免费漂过来。</view>
    <view class="invite-reward">{{inviteRewardRule}}</view>
  </view>
</view>
