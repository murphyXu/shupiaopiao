<view class="page page-tab" style="padding-top: {{navPaddingTop}}px;">
  <view class="page-header feed-header">
    <view>
      <view class="page-title">书单</view>
      <view class="page-sub">今天想读什么，随手翻翻</view>
    </view>
  </view>

  <view class="feed-grid">
    <view wx:for="{{feeds}}" wx:key="id" class="feed-card" data-id="{{item.id}}" bindtap="goDetail">
      <view class="cover">
        <image class="cover-img" src="{{item.coverImage}}" mode="aspectFill" />
      </view>
      <view class="feed-body">
        <view class="feed-title">{{item.cardTitle}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading">正在翻书单...</view>
  <view wx:if="{{!loading && !feeds.length}}" class="empty">暂时没有书单，稍后再试</view>
  <view wx:if="{{!loading && feeds.length && !hasMore}}" class="end">已经到底了</view>
</view>
