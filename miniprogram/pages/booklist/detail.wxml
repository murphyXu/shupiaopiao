<view class="page" wx:if="{{list}}">
  <view class="article-head card">
    <view class="article-title">{{list.cardTitle || list.title}}</view>
    <view class="article-meta">{{list.article && list.article.lead ? list.article.lead : list.theme}}</view>
    <view class="article-desc">{{list.description}}</view>
  </view>

  <view wx:if="{{list.article && list.article.sections.length}}" class="article card">
    <block wx:for="{{list.article.sections}}" wx:key="index">
      <view wx:if="{{item.type === 'paragraph'}}" class="paragraph">{{item.text}}</view>
      <view wx:elif="{{item.type === 'book'}}" class="inline-book" data-id="{{item.book.id}}" bindtap="goBook">
        <view class="inline-copy">
          <view class="inline-kicker">{{item.title}}</view>
          <view class="inline-text">{{item.text}}</view>
        </view>
        <view class="book-row">
          <image class="book-cover-sm" src="{{item.book.cover}}" mode="aspectFit" binderror="onCoverError" data-single="list.article.sections[{{index}}].book" data-isbn="{{item.book.isbn}}" />
          <view class="book-info">
            <view class="book-title">{{item.book.title}}</view>
            <view class="muted">{{item.book.author}}</view>
            <view class="actions" catchtap="stopProp">
              <text class="action" data-id="{{item.book.id}}" catchtap="addWant">加入想读</text>
              <text class="action accent" data-isbn="{{item.book.isbn}}" catchtap="findDrift">去漂流找同款</text>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view wx:else class="card">
    <view class="paragraph">{{list.description}}</view>
  </view>

  <view wx:if="{{list.books.length}}" class="section-title">文末相关图书</view>
  <view wx:for="{{list.books}}" wx:key="id" class="card book-item" data-id="{{item.id}}" bindtap="goBook">
    <image class="book-cover-sm" src="{{item.cover}}" mode="aspectFit" binderror="onCoverError" data-index="{{index}}" data-list-key="list.books" data-isbn="{{item.isbn}}" />
    <view class="info">
      <view class="book-title">{{item.title}}</view>
      <view class="muted">{{item.author}}</view>
      <view wx:if="{{item.versionLabel}}" class="version">{{item.versionLabel}}</view>
      <view class="actions" catchtap="stopProp">
        <text class="action" data-id="{{item.id}}" catchtap="addWant">加入想读</text>
        <text class="action accent" data-isbn="{{item.isbn}}" catchtap="findDrift">去漂流找同款</text>
      </view>
    </view>
  </view>

  <view wx:if="{{list.relatedLists && list.relatedLists.length}}" class="section-title">还可以接着看</view>
  <view class="related-grid">
    <view wx:for="{{list.relatedLists}}" wx:key="id" class="related-card" data-id="{{item.id}}" bindtap="goList">
      <view class="related-cover">
        <image class="related-cover-img" src="{{item.coverImage}}" mode="aspectFill" />
      </view>
      <view class="related-title">{{item.cardTitle || item.title}}</view>
    </view>
  </view>
</view>
