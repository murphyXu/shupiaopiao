.page { padding: 24rpx; padding-bottom: 80rpx; }

.article-head {
  padding: 34rpx 32rpx;
}

.article-title {
  font-size: 42rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #15211B;
}

.article-meta {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #0C7A4B;
  font-weight: 700;
}

.article-desc {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #46564e;
}

.article { padding: 36rpx 32rpx; }
.paragraph {
  font-size: 30rpx;
  color: #24342b;
  line-height: 1.9;
  margin-bottom: 30rpx;
}

.inline-book {
  background: #f6fbf8;
  border: 1rpx solid #dcefe4;
  border-radius: 30rpx;
  padding: 24rpx;
  margin: 8rpx 0 34rpx;
}

.inline-kicker {
  font-size: 24rpx;
  color: #0C7A4B;
  font-weight: 800;
}

.inline-text {
  margin-top: 6rpx;
  color: #46564e;
  font-size: 25rpx;
  line-height: 1.6;
}

.book-row,
.book-item {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.book-row { margin-top: 20rpx; }
.book-item { padding: 24rpx; }
.book-row .book-cover-sm,
.book-item .book-cover-sm {
  width: 128rpx;
  height: 174rpx;
  border-radius: 18rpx;
}

.book-info,
.info {
  flex: 1;
  min-width: 0;
}

.book-title {
  font-size: 28rpx;
  color: #15211B;
  font-weight: 800;
  line-height: 1.35;
}

.version {
  margin-top: 4rpx;
  color: #7b8a82;
  font-size: 22rpx;
  line-height: 1.4;
}

.actions {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.action {
  font-size: 24rpx;
  color: #2FBE77;
  font-weight: 700;
}

.action.accent { color: #0C7A4B; }

.section-title {
  margin: 36rpx 4rpx 18rpx;
  font-size: 28rpx;
  color: #15211B;
  font-weight: 900;
}

.related-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.related-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 18rpx;
  box-shadow: 0 16rpx 48rpx rgba(21, 158, 99, 0.08);
}

.related-cover {
  width: 100%;
  padding-top: 125%;
  border-radius: 22rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  background: #eef3ef;
}

.related-cover-img {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.related-title {
  margin-top: 14rpx;
  color: #15211B;
  font-size: 25rpx;
  line-height: 1.35;
  font-weight: 800;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
