@import '../../styles/common.wxss';

.page { padding-bottom: 48rpx; }
.cover-frame {
  width: 100%;
  height: 420rpx;
  background: #fff;
  border-radius: 28rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 20rpx 80rpx rgba(21, 158, 99, 0.08);
}
.cover { width: 100%; height: 100%; background: transparent; }
.title { font-size: 36rpx; font-weight: 700; color: #15211B; }
.author { font-size: 28rpx; margin-top: 8rpx; }
.isbn { font-size: 22rpx; color: #9aa8a0; margin-top: 12rpx; }
.section-title { font-size: 28rpx; font-weight: 800; color: #15211B; margin-bottom: 18rpx; }
.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  font-size: 25rpx;
  line-height: 1.7;
}
.info-row text:first-child { color: #7b8a82; flex-shrink: 0; }
.info-row text:last-child { color: #15211B; text-align: right; }
.tag {
  display: inline-block;
  font-size: 22rpx;
  background: #f0f5f1;
  color: #46564e;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  margin: 16rpx 12rpx 0 0;
}
.tag.mint { background: #EAFBF2; color: #0C7A4B; }
.summary { font-size: 26rpx; line-height: 1.7; margin-top: 20rpx; color: #46564e; }
.page .btn-primary, .page .btn-ghost { margin: 16rpx 44rpx 0; }
