.page { padding-bottom: 40rpx; }
.cover-card {
  background: #fff;
  border-radius: 36rpx;
  margin: 0 0 24rpx;
  padding: 20rpx;
  box-shadow: 0 20rpx 80rpx rgba(21, 158, 99, 0.08);
}
.cover-frame {
  width: 100%;
  height: 520rpx;
  border-radius: 24rpx;
  background: #fff;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover {
  width: 100%;
  height: 100%;
  background: transparent;
}
.title { font-size: 36rpx; font-weight: 800; color: #15211B; line-height: 1.35; }
.author { font-size: 28rpx; margin-top: 8rpx; }
.summary { font-size: 26rpx; line-height: 1.7; margin-top: 16rpx; color: #46564e; }
.section-title { font-size: 28rpx; font-weight: 800; color: #15211B; margin-bottom: 18rpx; }
.label { font-size: 26rpx; color: #7b8a82; margin: 24rpx 0 12rpx; font-weight: 700; }
.version-tip { margin-top: 12rpx; font-size: 24rpx; color: #0C7A4B; }
.info-grid { display: grid; gap: 14rpx; }
.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  font-size: 25rpx;
  line-height: 1.5;
}
.info-row text:first-child { color: #7b8a82; flex-shrink: 0; }
.info-row text:last-child { color: #15211B; text-align: right; }
.current-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 4rpx;
}
.current-meta text {
  font-size: 22rpx;
  color: #0C7A4B;
  background: #EAFBF2;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}
.stars { margin-bottom: 16rpx; }
.star { font-size: 40rpx; color: #d6dbe2; margin-right: 8rpx; }
.star.on { color: #f5a623; }
.custom-location {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-top: 6rpx;
}
.custom-location input {
  flex: 1;
  width: 100%;
  min-height: 88rpx;
  border: 1rpx solid #dbe7df;
  border-radius: 18rpx;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
  background: #fff;
  font-size: 26rpx;
}
.mini-btn {
  flex-shrink: 0;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #2FBE77;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}
.action-btn {
  margin: 16rpx 24rpx 0;
  min-height: 90rpx;
  padding: 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1.4;
}
.drift-status-btn {
  color: #0C7A4B;
  background: #EAFBF2;
  box-shadow: none;
}
.page .btn-primary, .page .btn-ghost { margin: 16rpx 24rpx 0; }
