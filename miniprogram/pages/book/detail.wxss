.page { padding-bottom: 40rpx; }
.cover-card {
  background: #fff;
  border-radius: 36rpx;
  margin: 0 0 24rpx;
  padding: 20rpx;
  box-shadow: 0 20rpx 80rpx rgba(21, 158, 99, 0.08);
}
.cover-frame {
  width: 100%;
  height: 520rpx;
  border-radius: 24rpx;
  background: #fff;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover {
  width: 100%;
  height: 100%;
  background: transparent;
}
.title { font-size: 36rpx; font-weight: 800; color: #15211B; line-height: 1.35; }
.author { font-size: 28rpx; margin-top: 8rpx; }
.summary { font-size: 26rpx; line-height: 1.7; margin-top: 16rpx; color: #46564e; }
.section-title { font-size: 28rpx; font-weight: 800; color: #15211B; margin-bottom: 18rpx; }
.shelf-info-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.drifted-out-pill {
  flex-shrink: 0;
  font-size: 22rpx;
  line-height: 1;
  color: #0C7A4B;
  background: #EAFBF2;
  border: 1rpx solid rgba(47, 190, 119, 0.28);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 700;
}
.meta-edit-tip {
  margin: -6rpx 0 16rpx;
  color: #b8860b;
  font-size: 24rpx;
  line-height: 1.45;
}
.inline-link {
  color: #2FBE77;
  font-weight: 700;
}
.label { font-size: 26rpx; color: #7b8a82; margin: 24rpx 0 12rpx; font-weight: 700; }
.version-tip { margin-top: 12rpx; font-size: 24rpx; color: #0C7A4B; }
.info-grid { display: grid; gap: 14rpx; }
.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  font-size: 25rpx;
  line-height: 1.5;
}
.info-row text:first-child { color: #7b8a82; flex-shrink: 0; }
.info-row text:last-child { color: #15211B; text-align: right; }
.drift-summary { margin-bottom: 12rpx; }
.stars { margin-bottom: 16rpx; }
.star { font-size: 40rpx; color: #d6dbe2; margin-right: 8rpx; }
.star.on { color: #f5a623; }
.custom-location {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-top: 6rpx;
}
.custom-location input {
  flex: 1;
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  border: 1rpx solid #dbe7df;
  border-radius: 18rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  background: #fff;
  font-size: 28rpx;
  line-height: 88rpx;
  color: #15211B;
}
.action-btn {
  margin: 16rpx 24rpx 0;
  min-height: 90rpx;
  padding: 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1.4;
}
.action-btn.is-saving {
  opacity: 0.72;
}
.drift-status-btn {
  color: #0C7A4B;
  background: #EAFBF2;
  box-shadow: none;
}
.hint {
  font-size: 24rpx;
  margin-bottom: 8rpx;
}
.chips {
  display: grid;
  gap: 10rpx;
  padding-bottom: 0;
}
.status-chips {
  grid-template-columns: repeat(3, 1fr);
}
.class-chips {
  grid-template-columns: repeat(4, 1fr);
}
.location-chips {
  grid-template-columns: repeat(3, 1fr);
}
.condition-chips {
  grid-template-columns: repeat(5, 1fr);
}
.issue-chips {
  grid-template-columns: repeat(3, 1fr);
}
.chips .chip {
  display: block;
  margin-right: 0;
  margin-bottom: 0;
  min-width: 0;
  padding: 13rpx 4rpx;
  text-align: center;
  white-space: nowrap;
  font-size: 22rpx;
  line-height: 1.2;
}
.price-line {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #46564e;
  margin-bottom: 12rpx;
}
.coin-stepper-row {
  margin-top: 8rpx;
}
.coin-stepper-label {
  font-size: 24rpx;
  color: #7b8a82;
  margin-bottom: 10rpx;
}
.coin-stepper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.stepper-btn {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 18rpx;
  background: #EAFBF2;
  color: #0C7A4B;
  font-size: 36rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.stepper-btn.disabled {
  opacity: 0.4;
  color: #9aa8a0;
  background: #f2f4f8;
}
.coin-stepper-value {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #15211B;
}
.coin-hint {
  font-size: 24rpx;
  line-height: 1.6;
  margin-top: 12rpx;
}
.page .btn-primary, .page .btn-ghost { margin: 16rpx 24rpx 0; }
