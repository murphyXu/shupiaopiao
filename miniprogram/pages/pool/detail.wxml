<view class="page" wx:if="{{item}}">
  <view class="shot-frame">
    <image src="{{item.book.cover}}" mode="aspectFit" class="slide-img" binderror="onCoverError" data-single="item.book" data-isbn="{{item.book.isbn}}" />
  </view>

  <view class="card">
    <view class="title">{{item.book.title}}</view>
    <view class="muted author">{{item.book.author}}</view>
    <view class="row-meta">
      <text class="coin big">流转积分 {{item.coinValue}}</text>
      <text class="pill">{{item.conditionLabel}}</text>
      <text wx:if="{{item.lightweightHint}}" class="pill lightweight">轻量</text>
    </view>
    <view wx:if="{{item.conditionIssueLabels && item.conditionIssueLabels.length}}" class="issue-row">
      <text wx:for="{{item.conditionIssueLabels}}" wx:key="*this" class="pill issue-pill">{{item}}</text>
    </view>
    <view class="report-link" bindtap="reportItem">举报</view>
  </view>

  <view wx:if="{{item.sameGiverPool}}" class="card same-giver-card">
    <view class="same-giver-label">{{item.sameGiverPool.label}}</view>
    <view class="muted same-giver-tip">凑单通常只需一次到付运费，点击查看详情</view>
    <view
      wx:for="{{item.sameGiverPool.items}}"
      wx:key="id"
      class="same-giver-item row"
      hover-class="same-giver-item-hover"
      bindtap="goSameGiverItem"
      data-id="{{item.id}}"
    >
      <image class="book-cover-sm" src="{{item.book.cover}}" mode="aspectFill" binderror="onCoverError" data-index="{{index}}" data-list-key="item.sameGiverPool.items" data-nested-key="book" data-isbn="{{item.book.isbn}}" />
      <view class="same-giver-info">
        <view class="same-giver-title">{{item.book.title}}</view>
        <view class="same-giver-meta">
          <text class="coin">流转积分 {{item.coinValue}}</text>
          <text wx:if="{{item.lightweightHint}}" class="pill lightweight">轻量</text>
        </view>
      </view>
      <text class="same-giver-arrow">›</text>
    </view>
  </view>

  <view class="card giver">
    <view class="avatar-circle sm"></view>
    <view>
      <view class="giver-name">{{item.giver.nickname}}</view>
      <view class="muted">信用积分 {{item.giver.creditScore}}</view>
      <view wx:if="{{item.shipFrom}}" class="ship-from-line">寄出地：{{item.shipFrom.label}}</view>
    </view>
  </view>

  <view class="tip">运费采用快递到付，由接漂方与快递公司线下结算，平台不收取任何费用{{item.shipFrom ? '；实际运费以快递员收费为准' : ''}}。</view>

  <view class="fixed-actions {{item.isMine ? 'mine-actions' : ''}}">
    <view wx:if="{{!item.isMine}}" class="btn-ghost want-btn {{item.wanted ? 'active' : ''}}" bindtap="toggleWant">{{item.wanted ? '已想要' : '想要接漂'}}</view>
    <view wx:if="{{item.canClaim}}" class="btn-primary claim-btn" bindtap="goClaim">申请接漂</view>
    <view wx:elif="{{item.isMine}}" class="btn-ghost claim-btn mine-only-btn">我的赠书</view>
  </view>
</view>
