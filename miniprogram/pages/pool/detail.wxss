.images {
  height: 520rpx;
  border-radius: 30rpx;
  overflow: hidden;
  background: #fff;
  margin-bottom: 24rpx;
}

.shot-frame {
  width: 100%;
  height: 520rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.slide-img {
  width: 100%;
  height: 100%;
  background: #fff;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #15211B;
}

.author {
  font-size: 24rpx;
  margin-top: 6rpx;
}

.row-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
}

.issue-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.issue-pill {
  margin: 0;
}

.coin.big {
  font-size: 32rpx;
  padding: 12rpx 24rpx;
}

.giver {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.giver-name {
  font-size: 28rpx;
  font-weight: 600;
}

.ship-from-line {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #46564e;
}

.page {
  padding-bottom: 200rpx;
}

.tip {
  margin-bottom: 40rpx;
}

.fixed-actions {
  position: fixed;
  left: 44rpx;
  right: 44rpx;
  bottom: calc(48rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: 220rpx 1fr;
  gap: 18rpx;
}

.fixed-actions.mine-actions {
  left: 0;
  right: 0;
  bottom: calc(56rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: center;
  padding: 0 44rpx;
}

.fixed-actions .btn-ghost,
.fixed-actions .btn-primary {
  padding: 26rpx 12rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
}

.mine-only-btn {
  width: 360rpx;
  max-width: 100%;
  text-align: center;
  color: #7b8a82;
  background: #f0f5f1;
  border: 1rpx solid #e6eee9;
  box-shadow: none;
}

.want-btn.active {
  background: #2FBE77;
  color: #fff;
}

.pill.lightweight,
.lightweight {
  background: #EAFBF2;
  color: #0C7A4B;
}

.same-giver-card {
  background: #EAFBF2;
  border: 1rpx solid #c8efd9;
}

.same-giver-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #0C7A4B;
}

.same-giver-tip {
  margin-top: 8rpx;
  margin-bottom: 20rpx;
}

.same-giver-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #c8efd9;
}

.same-giver-item-hover {
  opacity: 0.72;
}

.same-giver-info {
  flex: 1;
  min-width: 0;
}

.same-giver-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #15211B;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.same-giver-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.same-giver-arrow {
  font-size: 36rpx;
  color: #0C7A4B;
  line-height: 1;
}
