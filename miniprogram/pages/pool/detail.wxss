.images {
  height: 520rpx;
  border-radius: 30rpx;
  overflow: hidden;
  background: #fff;
  margin-bottom: 24rpx;
}

.shot-frame {
  position: relative;
  width: 100%;
  height: 520rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-mine-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  z-index: 2;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #7b8a82;
  background: rgba(240, 245, 241, 0.94);
  border: 1rpx solid #e6eee9;
}

.slide-img {
  width: 100%;
  height: 100%;
  background: #fff;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #15211B;
}

.author {
  font-size: 24rpx;
  margin-top: 6rpx;
}

.row-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
}

.mine-status-line {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #7b8a82;
  line-height: 1.5;
}

.issue-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.detail-ship-line {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #46564e;
}

.know-card {
  background: #edf8f2;
  border: 1rpx solid #dcefe4;
}

.know-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #0C7A4B;
  margin-bottom: 16rpx;
}

.know-line {
  position: relative;
  padding-left: 26rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #46564e;
}

.know-line::before {
  content: "";
  position: absolute;
  left: 6rpx;
  top: 17rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #2FBE77;
}

.issue-pill {
  margin: 0;
}

.coin.big {
  font-size: 32rpx;
  padding: 12rpx 24rpx;
}

.giver {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.giver-avatar,
.avatar-placeholder.sm {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.giver-avatar {
  background: #fff;
}

.giver-name {
  font-size: 28rpx;
  font-weight: 600;
}

.ship-from-line {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #46564e;
}

.page-mine {
  padding-bottom: 48rpx;
}

.page-claimable {
  padding-bottom: 200rpx;
}

.tip {
  margin-bottom: 40rpx;
}

.guide-link {
  margin: -8rpx 0 24rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #0C7A4B;
  line-height: 1;
  white-space: nowrap;
}

.mine-given-link {
  margin: 8rpx 0 24rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #0C7A4B;
}

.fixed-actions {
  position: fixed;
  left: 44rpx;
  right: 44rpx;
  bottom: calc(48rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: 220rpx 1fr;
  gap: 18rpx;
}

.fixed-actions .btn-ghost,
.fixed-actions .btn-primary {
  padding: 26rpx 12rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
}

.want-btn.active {
  background: #2FBE77;
  color: #fff;
}

.pill.lightweight,
.lightweight {
  background: #EAFBF2;
  color: #0C7A4B;
}

.same-giver-card {
  background: #EAFBF2;
  border: 1rpx solid #c8efd9;
}

.same-giver-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #0C7A4B;
}

.same-giver-tip {
  margin-top: 8rpx;
  margin-bottom: 20rpx;
}

.same-giver-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #c8efd9;
}

.same-giver-item-hover {
  opacity: 0.72;
}

.same-giver-info {
  flex: 1;
  min-width: 0;
}

.same-giver-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #15211B;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.same-giver-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.same-giver-arrow {
  font-size: 36rpx;
  color: #0C7A4B;
  line-height: 1;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #15211B;
  margin-bottom: 18rpx;
}

.summary {
  font-size: 26rpx;
  line-height: 1.7;
  color: #46564e;
}

.summary-clamped {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
}

.summary-toggle {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #0C7A4B;
  font-weight: 600;
}

.info-grid {
  display: grid;
  gap: 14rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  font-size: 25rpx;
  line-height: 1.5;
}

.info-row text:first-child {
  color: #7b8a82;
  flex-shrink: 0;
}

.info-row text:last-child {
  color: #15211B;
  text-align: right;
}
