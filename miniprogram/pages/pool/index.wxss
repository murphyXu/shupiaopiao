.pool-stat-card-hover {
  opacity: 0.82;
  transform: scale(0.98);
}

.pool-title-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 14rpx;
}

.pool-title-row .page-title {
  flex: 0 1 216rpx;
  min-width: 0;
}

.guide-entry {
  flex-shrink: 0;
  position: relative;
  box-sizing: border-box;
  width: 156rpx;
  padding: 9rpx 18rpx 10rpx;
  border: 2rpx solid #2FBE77;
  border-radius: 10rpx;
  color: #0C7A4B;
  background: linear-gradient(180deg, #FFFDF3 0%, #EAFBF2 100%);
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.1;
  white-space: nowrap;
  box-shadow: 0 8rpx 0 #BDEBCD, 0 12rpx 22rpx rgba(21, 158, 99, 0.14);
  transform: rotate(-2deg);
}

.guide-entry::before,
.guide-entry::after {
  content: "";
  position: absolute;
  top: -8rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #2FBE77;
}

.guide-entry::before {
  left: 14rpx;
}

.guide-entry::after {
  right: 14rpx;
}

.pool-point-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
  margin-top: 8rpx;
}

.pool-point-line {
  flex: 0 1 216rpx;
  min-width: 0;
  margin-top: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 22rpx;
}

.earn-point-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
  width: 132rpx;
  height: 56rpx;
  padding: 0;
  border-radius: 28rpx;
  background: #EAFBF2;
  color: #0C7A4B;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.primary-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  background: #f0f5f1;
  border-radius: 28rpx;
  padding: 8rpx;
  margin-bottom: 18rpx;
}

.primary-tab {
  text-align: center;
  font-size: 25rpx;
  padding: 16rpx 8rpx;
  border-radius: 20rpx;
  color: #7b8a82;
  font-weight: 700;
}

.primary-tab.active {
  background: #fff;
  color: #159E63;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.filter-scroll {
  white-space: nowrap;
  margin-bottom: 26rpx;
}

.pool-search-box {
  display: flex;
  align-items: center;
  gap: 14rpx;
  box-sizing: border-box;
  height: 76rpx;
  margin: 0 0 24rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e6eee9;
  border-radius: 28rpx;
  background: #fff;
}

.pool-search-box input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  color: #15211B;
  font-size: 25rpx;
}

.secondary-tabs {
  display: inline-flex;
  gap: 14rpx;
  min-width: 100%;
}

.secondary-tab {
  display: inline-flex;
  align-items: center;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 30rpx;
  background: #fff;
  color: #46564e;
  border: 1rpx solid #e6eee9;
  font-size: 24rpx;
  font-weight: 600;
}

.secondary-tab.active {
  background: #2FBE77;
  color: #fff;
  border-color: #2FBE77;
}

.pool-grid {
  margin-top: 8rpx;
}

.pool-card {
  background: #fff;
  border: 1rpx solid #eef3ef;
  border-radius: 36rpx;
  padding: 20rpx;
  box-shadow: 0 12rpx 40rpx rgba(21, 158, 99, 0.06);
}

.cover-frame {
  width: 100%;
  height: 260rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-frame .book-cover {
  width: 100%;
  height: 100%;
  background: transparent;
}

.book-title {
  font-size: 26rpx;
  font-weight: 600;
  margin-top: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.apply-action {
  margin-top: 14rpx;
  height: 54rpx;
  line-height: 54rpx;
  border-radius: 28rpx;
  text-align: center;
  color: #fff;
  background: #2FBE77;
  border: 1rpx solid #2FBE77;
  font-size: 23rpx;
  font-weight: 700;
}

.pool-publish-entry {
  position: fixed;
  left: 50%;
  bottom: calc(126rpx + env(safe-area-inset-bottom));
  transform: translateX(-50%);
  min-width: 188rpx;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 40rpx;
  background: #2FBE77;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 14rpx 34rpx rgba(47, 190, 119, 0.34);
  z-index: 100;
}

.publish-icon {
  font-size: 34rpx;
  line-height: 1;
  font-weight: 300;
}

.publish-text {
  font-size: 26rpx;
  font-weight: 700;
}
