<view class="page page-tab shelf-page" style="padding-top: {{navPaddingTop}}px;">
  <custom-nav-bar title="书架" />
  <view class="page-header shelf-header">
    <view class="title-row">
      <view class="page-title shelf-title">{{shelfName}}</view>
    </view>
    <view class="capacity-row">
      <view wx:if="{{shareMode}}" class="capacity-stats page-sub">
        <text class="stat-item">在架 {{dashboard.totalBooks}} 本</text>
      </view>
      <view wx:elif="{{loggedIn}}" class="capacity-stats page-sub">
        <text class="stat-item">在架 {{dashboard.totalBooks}} 本</text>
        <text class="stat-sep">·</text>
        <text class="stat-item">剩余可添加 {{dashboard.remainingCapacity}} 本</text>
      </view>
      <view wx:else class="capacity-stats page-sub">
        <text class="stat-item">登录后查看书架统计</text>
      </view>
      <view wx:if="{{loggedIn && !shareMode}}" class="quota-action" bindtap="goRedeemCapacity">兑换额度 ›</view>
    </view>
  </view>

  <view wx:if="{{shareMode}}" class="share-exit card" bindtap="exitShareMode">
    <view>
      <view class="share-exit-title">正在查看分享书架</view>
      <view class="muted">返回小程序后可切回自己的书架内容</view>
    </view>
    <view class="share-exit-btn">回到我的书架</view>
  </view>

  <view class="sticky-search-filter" style="top: {{stickyTop}}px;">
    <view wx:if="{{loggedIn || shareMode}}" class="shelf-search">
      <input value="{{searchKeyword}}" placeholder="搜索书名、作者、ISBN、出版社" bindinput="onShelfSearchInput" />
      <view wx:if="{{searchKeyword}}" class="search-clear" bindtap="clearShelfSearch">清除</view>
    </view>

    <view class="shelf-filter-bar">
      <view class="filter-chips">
        <view wx:for="{{categoryChips}}" wx:key="key" class="filter-chip {{activeCategory === item.key ? 'active' : ''}}" data-key="{{item.key}}" bindtap="onCategoryChip">{{item.label}}</view>
        <view class="filter-chip more {{moreActive ? 'active' : ''}}" bindtap="openMoreFilter">更多<text class="chip-caret">{{showMoreFilter ? '▴' : '▾'}}</text></view>
      </view>
    </view>
  </view>

  <view wx:if="{{books.length}}" class="grid-2">
    <view wx:for="{{books}}" wx:key="id" class="grid-book-card" data-id="{{item.id}}" data-book-id="{{item.bookId}}" bindtap="goDetail">
      <view class="grid-book-cover-frame shelf-cover-frame">
        <view wx:if="{{item.driftedOut}}" class="drifted-out-tag">已漂出</view>
        <image class="book-cover" src="{{item.book.cover}}" mode="aspectFit" binderror="onCoverError" data-isbn="{{item.book.isbn}}" />
      </view>
      <view class="grid-book-title">{{item.book.title}}</view>
      <view class="grid-book-subline">{{item.book.author}}{{item.readingStatusLabel ? ' · ' + item.readingStatusLabel : ''}}</view>
    </view>
  </view>
  <view wx:else class="empty">
    <block wx:if="{{shareMode}}">这个分组暂时没有书</block>
    <block wx:elif="{{categoryFilterPending}}">正在加载该分类…</block>
    <block wx:elif="{{searchKeyword}}">没找到这本在架书，换个书名、作者或 ISBN 试试</block>
    <block wx:elif="{{loggedIn}}">书架空空如也，扫码添加第一本书吧</block>
    <block wx:else>
      <view class="guest-empty">
        <text class="guest-empty-text">登录后可管理个人书架</text>
        <view class="guest-login-btn" bindtap="goLogin">微信一键登录</view>
      </view>
    </block>
  </view>

  <view wx:if="{{loggedIn && !shareMode}}" class="add-book-entry" bindtap="showAddMenu">
    <text class="add-icon">＋</text>
    <text class="add-text">添加书籍</text>
  </view>

  <view wx:if="{{showBackTop}}" class="back-top-entry" bindtap="scrollToTop">
    <text>↑</text>
    <text>顶部</text>
  </view>
</view>

<page-container
  show="{{showMoreFilter}}"
  position="bottom"
  round
  overlay
  z-index="10050"
  bind:clickoverlay="closeMoreFilter">
  <view class="more-filter-panel {{filterCompact ? 'compact' : ''}}">
    <view class="mf-head">
      <text>更多筛选</text>
      <text class="mf-close" bindtap="closeMoreFilter">✕</text>
    </view>
    <view class="mf-body">
      <view class="mf-section">
        <view class="mf-label">阅读状态</view>
        <view class="mf-opts">
          <view wx:for="{{statusOpts}}" wx:key="key" class="mf-opt {{draftStatus === item.key ? 'on' : ''}}" data-key="{{item.key}}" bindtap="onDraftStatus">{{item.label}}</view>
        </view>
      </view>
      <view class="mf-section">
        <view class="mf-label">书架位置</view>
        <view class="mf-opts">
          <view wx:for="{{locationOpts}}" wx:key="key" class="mf-opt {{draftLocation === item.key ? 'on' : ''}}" data-key="{{item.key}}" bindtap="onDraftLocation">{{item.label}}</view>
        </view>
      </view>
    </view>
    <view class="mf-foot" style="padding-bottom: {{filterFootPadding}}px;">
      <view class="mf-btn ghost" bindtap="resetMoreFilter">重置</view>
      <view class="mf-btn primary" bindtap="applyMoreFilter">查看结果</view>
    </view>
  </view>
</page-container>
