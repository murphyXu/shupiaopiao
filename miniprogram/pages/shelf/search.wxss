.page { padding: 24rpx; }
.search-bar { display: flex; gap: 16rpx; align-items: center; }
.search-bar input { flex: 1; }
.search-btn { padding: 16rpx 28rpx; font-size: 26rpx; }
.loading-card { text-align: center; background: linear-gradient(135deg, #fff, #f2fff8); }
.loading-title { font-size: 30rpx; color: #15211B; font-weight: 700; }
.quote { margin: 12rpx 0 8rpx; color: #0C7A4B; font-size: 28rpx; font-weight: 600; }
.result-head { display: flex; justify-content: space-between; align-items: flex-end; margin: 8rpx 4rpx 20rpx; font-size: 28rpx; font-weight: 700; color: #15211B; }
.search-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24rpx; }
.result-item { min-width: 0; margin-bottom: 0; padding: 20rpx; }
.result-item .book-cover-sm { width: 100%; height: 260rpx; border-radius: 20rpx; margin-bottom: 12rpx; }
.info { min-width: 0; }
.title { font-size: 26rpx; font-weight: 600; line-height: 1.35; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.author { font-size: 22rpx; line-height: 1.35; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
.version-tip { margin-top: 8rpx; font-size: 21rpx; color: #0C7A4B; line-height: 1.35; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.empty-title { color: #15211B; font-weight: 700; margin-bottom: 10rpx; }
.empty-desc { font-size: 25rpx; line-height: 1.6; margin-bottom: 24rpx; }
.manual-btn { margin-top: 20rpx; }
