.shelf-page {
  padding-bottom: 156rpx;
}

.shelf-header {
  min-width: 0;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.shelf-title {
  flex: 0 1 216rpx;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header-action {
  flex-shrink: 0;
  width: 132rpx;
  height: 56rpx;
}

.edit-name {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a988f;
}

.edit-pencil {
  font-size: 30rpx;
  line-height: 1;
  color: #8a988f;
}

.capacity-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
  margin-top: 8rpx;
}

.capacity-stats {
  flex: 0 1 auto;
  max-width: calc(100% - 146rpx);
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 0;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  font-size: 22rpx;
}

.stat-item {
  flex-shrink: 0;
}

.stat-sep {
  flex-shrink: 0;
  color: #c5d0ca;
}

.quota-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
  width: 132rpx;
  height: 56rpx;
  padding: 0;
  border-radius: 28rpx;
  background: #EAFBF2;
  color: #0C7A4B;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.shelf-stat-row {
  margin-bottom: 36rpx;
}

.shelf-stat-row .stat-card {
  min-height: 132rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.shelf-search {
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: #fff;
  border: 1rpx solid #e6eee9;
  border-radius: 28rpx;
  padding: 0 20rpx;
  height: 76rpx;
  margin: 0 0 24rpx;
  box-sizing: border-box;
}

.shelf-search input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  font-size: 25rpx;
  color: #15211B;
}

.search-clear {
  flex-shrink: 0;
  color: #0C7A4B;
  font-size: 23rpx;
  font-weight: 700;
}

.shelf-name-editor {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.shelf-name-editor input {
  width: 320rpx;
  height: 72rpx;
  border: 1rpx solid #dbe7df;
  border-radius: 22rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  background: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.mini-save {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: #2FBE77;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.share-exit {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 24rpx;
}

.share-exit-title {
  color: #15211B;
  font-size: 26rpx;
  font-weight: 800;
}

.share-exit-btn {
  flex-shrink: 0;
  color: #fff;
  background: #2FBE77;
  border-radius: 24rpx;
  padding: 14rpx 22rpx;
  font-size: 24rpx;
  font-weight: 700;
}

/* 更多筛选抽屉 */
.more-filter-panel {
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  padding: 28rpx 32rpx 0;
  background: #fff;
}

.mf-head {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 800;
  color: #15211B;
}

.mf-close {
  margin-left: auto;
  color: #9aa8a0;
  font-size: 34rpx;
  padding: 8rpx 0 8rpx 16rpx;
}

.mf-body {
  flex-shrink: 0;
  margin-top: 8rpx;
}

.mf-section + .mf-section {
  margin-top: 24rpx;
}

.mf-label {
  margin: 0 0 14rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #7b8a82;
}

.mf-opts {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.mf-opt {
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  border: 1rpx solid #e6eee9;
  background: #fff;
  color: #46564e;
  font-size: 23rpx;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
}

.mf-opt.on {
  background: #EAFBF2;
  border-color: #2FBE77;
  color: #0C7A4B;
  font-weight: 700;
}

.mf-foot {
  flex-shrink: 0;
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
  padding-top: 8rpx;
}

.mf-btn {
  height: 84rpx;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.more-filter-panel.compact {
  padding-top: 24rpx;
}

.more-filter-panel.compact .mf-section + .mf-section {
  margin-top: 18rpx;
}

.more-filter-panel.compact .mf-label {
  margin-bottom: 12rpx;
}

.more-filter-panel.compact .mf-opt {
  height: 52rpx;
  padding: 0 22rpx;
  font-size: 22rpx;
}

.more-filter-panel.compact .mf-foot {
  margin-top: 22rpx;
}

.more-filter-panel.compact .mf-btn {
  height: 76rpx;
  font-size: 27rpx;
}

.mf-btn.ghost {
  flex: 1;
  background: #f0f5f1;
  color: #46564e;
}

.mf-btn.primary {
  flex: 2;
  background: #2FBE77;
  color: #fff;
}

.add-book-entry {
  position: fixed;
  left: 50%;
  bottom: calc(126rpx + env(safe-area-inset-bottom));
  transform: translateX(-50%);
  min-width: 176rpx;
  height: 64rpx;
  padding: 0 26rpx;
  border-radius: 34rpx;
  background: #fff;
  border: 2rpx solid #2FBE77;
  color: #0C7A4B;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 12rpx 28rpx rgba(47, 190, 119, 0.16);
  z-index: 100;
}

.add-icon {
  font-size: 32rpx;
  line-height: 1;
  font-weight: 600;
}

.add-text {
  font-size: 24rpx;
  font-weight: 700;
}

.location-line {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7b8a82;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.shelf-cover-frame {
  position: relative;
}

.drifted-out-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  z-index: 1;
  font-size: 20rpx;
  line-height: 1;
  color: #0C7A4B;
  background: rgba(234, 251, 242, 0.96);
  border: 1rpx solid rgba(47, 190, 119, 0.28);
  padding: 8rpx 14rpx;
  border-radius: 16rpx;
  font-weight: 700;
}

.book-extra {
  margin-top: 8rpx;
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.book-extra text {
  font-size: 22rpx;
  color: #9aa8a0;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.back-top-entry {
  position: fixed;
  right: 34rpx;
  bottom: calc(126rpx + env(safe-area-inset-bottom));
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  background: #fff;
  border: 1rpx solid #dcefe4;
  color: #0C7A4B;
  box-shadow: 0 12rpx 34rpx rgba(21, 158, 99, 0.14);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  z-index: 101;
}

.back-top-entry text:first-child {
  font-size: 28rpx;
  line-height: 1;
}

.guest-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.guest-empty-text {
  display: block;
  margin-bottom: 24rpx;
}
