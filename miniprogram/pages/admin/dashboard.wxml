<view class="page" style="padding-top: {{navPaddingTop}}px;">
  <view class="header">
    <text class="title">书漂漂 · 数据看板</text>
    <text class="subtitle">内部运营数据 · 仅管理员可见</text>
  </view>

  <view wx:if="{{loading}}" class="state">数据加载中…</view>

  <view wx:elif="{{denied}}" class="state denied">
    <text class="state-emoji">🔒</text>
    <text>无权访问，请在云函数环境变量 ADMIN_OPENIDS 中配置你的 openid</text>
  </view>

  <block wx:else>
    <view class="toolbar">
      <view class="tool-btn" bindtap="goLogs">查看明细</view>
      <view class="tool-btn secondary {{rebuilding ? 'disabled' : ''}}" bindtap="rebuildMetrics">{{rebuilding ? '重算中…' : '重算昨日'}}</view>
    </view>

    <view class="section-title">
      今日实时
      <text class="section-hint">实时</text>
      <text wx:if="{{todayLive.refreshedAtText}}" class="section-day">更新于 {{todayLive.refreshedAtText}}</text>
    </view>
    <view wx:if="{{todayLiveLoading && !todayLive}}" class="live-loading">刷新中…</view>
    <block wx:elif="{{todayLive}}">
      <view class="cards">
        <view class="card"><text class="num">{{todayLive.dau}}</text><text class="label">日活</text></view>
        <view class="card"><text class="num">{{todayLive.newUsers}}</text><text class="label">新增用户</text></view>
        <view class="card"><text class="num">{{todayLive.driftPublished}}</text><text class="label">上漂</text></view>
        <view class="card"><text class="num">{{todayLive.driftClaimed}}</text><text class="label">被接漂</text></view>
        <view class="card"><text class="num">{{todayLive.driftShipped}}</text><text class="label">已寄出</text></view>
        <view class="card"><text class="num">{{todayLive.driftDone}}</text><text class="label">完成漂流</text></view>
      </view>
      <view class="week today-live-extra">
        <view class="week-row"><text>积分发行 / 消耗</text><text class="week-val">{{todayLive.coinIssued}} / {{todayLive.coinConsumed}}</text></view>
        <view class="week-row"><text>接口调用 / 错误率</text><text class="week-val">{{todayLive.apiCalls}} · {{todayLive.errorRateText}}</text></view>
        <view wx:if="{{todayLive.driftCancelled || todayLive.driftDisputed}}" class="week-row">
          <text>异常</text>
          <text class="week-val abnormal">取消 {{todayLive.driftCancelled}} · 纠纷 {{todayLive.driftDisputed}}</text>
        </view>
      </view>
    </block>

    <view class="section-title">昨日概览<text wx:if="{{overview.today.day}}" class="section-day">（{{overview.today.day}}）</text></view>
    <view class="cards">
      <view class="card"><text class="num">{{overview.today.dau}}</text><text class="label">日活</text></view>
      <view class="card"><text class="num">{{overview.today.newUsers}}</text><text class="label">新增用户</text></view>
      <view class="card"><text class="num">{{overview.today.driftPublished}}</text><text class="label">上漂</text></view>
      <view class="card"><text class="num">{{overview.today.driftDone}}</text><text class="label">完成漂流</text></view>
    </view>

    <view class="section-title">累计概览<text class="section-hint">实时</text></view>
    <view class="cards">
      <view class="card"><text class="num">{{overview.cumulative.totalUsers}}</text><text class="label">累计用户</text></view>
      <view class="card"><text class="num">{{overview.cumulative.driftPublished}}</text><text class="label">累计上漂</text></view>
      <view class="card"><text class="num">{{overview.cumulative.driftOrders}}</text><text class="label">累计接漂</text></view>
      <view class="card"><text class="num">{{overview.cumulative.driftDone}}</text><text class="label">累计完成</text></view>
      <view class="card"><text class="num">{{overview.cumulative.inPool}}</text><text class="label">在漂中</text></view>
      <view class="card"><text class="num">{{overview.cumulative.inTransit}}</text><text class="label">在途订单</text></view>
      <view class="card"><text class="num">{{overview.cumulative.coinStock}}</text><text class="label">积分存量</text></view>
      <view class="card"><text class="num">{{overview.cumulative.coinIssued}}</text><text class="label">累计发行</text></view>
      <view class="card"><text class="num">{{overview.cumulative.coinConsumed}}</text><text class="label">累计消耗</text></view>
    </view>
    <view class="week cumulative-rates">
      <view class="week-row"><text>累计被接率</text><text class="week-val">{{overview.cumulativeText.claimRate}}</text></view>
      <view class="week-row"><text>累计完成率</text><text class="week-val">{{overview.cumulativeText.doneRate}}</text></view>
    </view>
    <view wx:if="{{overview.consumeBreakdown.length}}" class="week cumulative-breakdown">
      <view class="week-row breakdown-head">
        <text>消耗构成</text>
        <text class="week-val">合计 {{overview.cumulative.coinConsumed}}</text>
      </view>
      <view wx:for="{{overview.consumeBreakdown}}" wx:key="type" class="week-row">
        <text>{{item.label}}<text wx:if="{{item.count}}" class="row-sub"> · {{item.count}} 笔</text></text>
        <text class="week-val">{{item.amount}}</text>
      </view>
      <view wx:if="{{overview.consumeHint}}" class="breakdown-hint">{{overview.consumeHint}}</view>
    </view>

    <view class="section-title">近 7 天</view>
    <view class="week">
      <view class="week-row"><text>日活均值</text><text class="week-val">{{overview.week.dauAvg}} <text class="{{overview.weekText.dauWoWUp ? 'up' : 'down'}}">{{overview.weekText.dauWoWUp ? '↑' : '↓'}}{{overview.weekText.dauWoW}}</text></text></view>
      <view class="week-row"><text>新增用户</text><text class="week-val">{{overview.week.newUsers}}</text></view>
      <view class="week-row"><text>积分发行 / 消耗</text><text class="week-val">{{overview.week.coinIssued}} / {{overview.week.coinConsumed}}</text></view>
      <view class="week-row"><text>次日留存</text><text class="week-val">{{overview.weekText.retentionD1}}</text></view>
      <view class="week-row"><text>接口错误率</text><text class="week-val">{{overview.weekText.errorRate}}</text></view>
    </view>

    <view class="section-title">趋势（近 {{trendDays}} 天 · {{trend.metricLabel}}）</view>
    <view class="trend-controls">
      <picker mode="selector" range="{{trendMetrics}}" range-key="label" value="{{trendMetricIndex}}" bindchange="pickTrendMetric">
        <view class="picker-chip">指标 ▾</view>
      </picker>
      <picker mode="selector" range="{{trendDaysOptions}}" range-key="label" value="{{trendDaysIndex}}" bindchange="pickTrendDays">
        <view class="picker-chip">范围 ▾</view>
      </picker>
    </view>
    <view class="chart">
      <view class="bars">
        <view wx:for="{{trend.bars}}" wx:key="day" class="bar-col">
          <text class="bar-value">{{item.value}}</text>
          <view class="bar" style="height: {{item.height}}%;"></view>
          <text class="bar-label">{{item.day}}</text>
        </view>
      </view>
    </view>

    <view class="section-title">漂流漏斗（近 {{funnel.rangeDays}} 天）</view>
    <view class="funnel">
      <view wx:for="{{funnel.stages}}" wx:key="label" class="funnel-row">
        <text class="funnel-label">{{item.label}}</text>
        <view class="funnel-bar-wrap">
          <view class="funnel-bar" style="width: {{item.width}}%;"></view>
        </view>
        <text class="funnel-value">{{item.value}}</text>
      </view>
      <view class="funnel-rates">
        <text>被接率 {{funnel.ratesText.publishToClaim}}</text>
        <text>整体完成率 {{funnel.ratesText.overall}}</text>
        <text class="abnormal">取消 {{funnel.abnormal.cancelled}} · 纠纷 {{funnel.abnormal.disputed}}</text>
      </view>
    </view>

    <view class="section-title">分析结论</view>
    <view class="conclusions">
      <view wx:for="{{conclusions}}" wx:key="text" class="conclusion conclusion-{{item.level}}">
        <text class="dot"></text>
        <text class="conclusion-text">{{item.text}}</text>
      </view>
    </view>

    <view class="tip">数据每日 00:30 自动聚合；今日实时每次进入刷新；events 明细保留 90 天；下拉可刷新</view>
  </block>
</view>
