.page {
  min-height: 100vh;
  background: #f4f8f5;
  padding: 0 22rpx 60rpx;
  box-sizing: border-box;
}
.header { padding: 24rpx 8rpx 8rpx; }
.title { display: block; font-size: 40rpx; font-weight: 700; color: #15211B; }
.subtitle { display: block; font-size: 24rpx; color: #8a9b91; margin-top: 6rpx; }

.state {
  margin-top: 120rpx; text-align: center; color: #8a9b91; font-size: 28rpx;
  display: flex; flex-direction: column; align-items: center; gap: 16rpx; padding: 0 60rpx;
}
.state-emoji { font-size: 72rpx; }
.denied { color: #c0392b; }

.section-title {
  font-size: 30rpx; font-weight: 700; color: #159E63;
  margin: 36rpx 8rpx 16rpx;
}

.cards {
  display: flex; flex-wrap: wrap; gap: 16rpx;
}
.card {
  width: calc((100% - 32rpx) / 3); box-sizing: border-box;
  background: #fff; border-radius: 24rpx; padding: 24rpx 16rpx;
  display: flex; flex-direction: column; align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(47,190,119,0.06);
}
.card .num { font-size: 44rpx; font-weight: 700; color: #15211B; }
.card .label { font-size: 22rpx; color: #8a9b91; margin-top: 8rpx; }

.week {
  background: #fff; border-radius: 24rpx; padding: 8rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(47,190,119,0.06);
}
.week-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 22rpx 0; border-bottom: 1rpx solid #f0f4f1; font-size: 28rpx; color: #4a5a51;
}
.week-row:last-child { border-bottom: none; }
.week-val { font-weight: 600; color: #15211B; }
.up { color: #159E63; font-size: 24rpx; }
.down { color: #e07a5f; font-size: 24rpx; }

.chart {
  background: #fff; border-radius: 24rpx; padding: 28rpx 20rpx 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(47,190,119,0.06);
}
.bars { display: flex; align-items: flex-end; height: 240rpx; gap: 6rpx; }
.bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; height: 100%; justify-content: flex-end; }
.bar {
  width: 60%; min-height: 4rpx; border-radius: 8rpx 8rpx 0 0;
  background: linear-gradient(180deg, #34C77B 0%, #159E63 100%);
}
.bar-label { font-size: 18rpx; color: #b3c0b8; margin-top: 8rpx; transform: scale(0.8); }

.funnel {
  background: #fff; border-radius: 24rpx; padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(47,190,119,0.06);
}
.funnel-row { display: flex; align-items: center; margin-bottom: 18rpx; }
.funnel-label { width: 140rpx; font-size: 26rpx; color: #4a5a51; }
.funnel-bar-wrap { flex: 1; background: #EAFBF2; border-radius: 12rpx; height: 36rpx; overflow: hidden; }
.funnel-bar { height: 100%; background: linear-gradient(90deg, #34C77B, #159E63); border-radius: 12rpx; }
.funnel-value { width: 80rpx; text-align: right; font-size: 26rpx; font-weight: 600; color: #15211B; }
.funnel-rates {
  display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 12rpx;
  font-size: 24rpx; color: #159E63;
}
.funnel-rates .abnormal { color: #b3938a; }

.conclusions {
  background: #fff; border-radius: 24rpx; padding: 12rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(47,190,119,0.06);
}
.conclusion {
  display: flex; align-items: flex-start; gap: 16rpx;
  padding: 22rpx 0; border-bottom: 1rpx solid #f0f4f1;
}
.conclusion:last-child { border-bottom: none; }
.dot { width: 14rpx; height: 14rpx; border-radius: 50%; margin-top: 10rpx; flex-shrink: 0; background: #b3c0b8; }
.conclusion-good .dot { background: #159E63; }
.conclusion-warn .dot { background: #e8a23d; }
.conclusion-info .dot { background: #4a90d9; }
.conclusion-text { flex: 1; font-size: 27rpx; line-height: 1.6; color: #4a5a51; }

.tip { text-align: center; font-size: 22rpx; color: #b3c0b8; margin-top: 32rpx; }
