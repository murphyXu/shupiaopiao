.result-page {
  text-align: center;
  padding: 60rpx 44rpx;
}

.icon {
  width: 168rpx;
  height: 168rpx;
  border-radius: 50%;
  margin: 0 auto 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  font-weight: 700;
}

.icon.ok {
  background: #EAFBF2;
  color: #2FBE77;
}

.icon.fail {
  background: #ffeaea;
  color: #ff4d4f;
}

.result-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #15211B;
}

.result-sub {
  font-size: 26rpx;
  margin-top: 12rpx;
  margin-bottom: 32rpx;
}

.checks {
  text-align: left;
}

.check-item {
  line-height: 2.2;
  font-size: 26rpx;
  color: #46564e;
}

.hero-coin.mini {
  margin-top: 28rpx;
  text-align: left;
}

.reason {
  text-align: left;
  color: #ff4d4f;
  line-height: 2.2;
  font-size: 26rpx;
}

.subscribe-btn {
  margin-top: 24rpx;
}

.subscribe-hint {
  font-size: 22rpx;
  margin-top: 12rpx;
  margin-bottom: 8rpx;
}

.btn-primary {
  margin-top: 16rpx;
}
