<view class="page">
  <view class="card">
    <view class="label">评分</view>
    <view class="stars">
      <text wx:for="{{stars}}" wx:for-item="star" wx:key="*this" class="star {{rating >= star ? 'on' : ''}}" data-rating="{{star}}" bindtap="setRating">★</text>
    </view>
  </view>

  <view class="btn-primary" bindtap="submit">提交评价</view>
</view>
