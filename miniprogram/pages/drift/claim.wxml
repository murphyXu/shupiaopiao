<view class="page" wx:if="{{item}}">
  <view class="card row">
    <image class="book-cover-sm" src="{{item.book.cover}}" mode="aspectFill" binderror="onCoverError" data-single="item.book" data-isbn="{{item.book.isbn}}" />
    <view class="info">
      <view class="title">{{item.book.title}}</view>
      <text class="badge">流转积分 {{item.coinValue}}</text>
      <text wx:if="{{item.lightweightHint}}" class="pill lightweight">轻量</text>
    </view>
  </view>

  <view wx:if="{{item.sameGiverPool}}" class="card same-giver-card">
    <view class="same-giver-label">{{item.sameGiverPool.label}}</view>
    <view class="muted same-giver-tip">凑单通常只需一次到付运费，点击查看详情</view>
    <view
      wx:for="{{item.sameGiverPool.items}}"
      wx:key="id"
      class="same-giver-item row"
      hover-class="same-giver-item-hover"
      bindtap="goSameGiverItem"
      data-id="{{item.id}}"
    >
      <image class="book-cover-sm" src="{{item.book.cover}}" mode="aspectFill" binderror="onCoverError" data-index="{{index}}" data-list-key="item.sameGiverPool.items" data-nested-key="book" data-isbn="{{item.book.isbn}}" />
      <view class="same-giver-info">
        <view class="same-giver-title">{{item.book.title}}</view>
        <view class="same-giver-meta">
          <text class="badge">流转积分 {{item.coinValue}}</text>
          <text wx:if="{{item.lightweightHint}}" class="pill lightweight">轻量</text>
        </view>
      </view>
      <text class="same-giver-arrow">›</text>
    </view>
  </view>

  <view class="card address-card" bindtap="selectAddress">
    <view class="label">收货地址</view>
    <view wx:if="{{address}}">
      <view>{{address.name}} {{address.phone}}</view>
      <view class="muted">{{address.region}} {{address.detail}}</view>
    </view>
    <view wx:else class="muted">点击选择 / 新增地址 ›</view>
  </view>
  <view class="btn-ghost wx-address-btn" bindtap="chooseWxAddress">读取微信地址</view>

  <view class="note-box">
    <view>运费说明：赠书方将寄出「快递到付」件，运费由你在收件时付给快递员，平台不收取任何费用。</view>
    <view wx:if="{{shippingHint}}" class="shipping-hint">{{shippingHint}}</view>
    <view wx:elif="{{item.shipFrom}}" class="shipping-hint">赠书方从{{item.shipFrom.label}}寄出，运费收件时向快递员支付</view>
  </view>

  <view class="card balance">
    <text>可用公益积分</text>
    <text class="badge">{{available}}</text>
    <text class="muted">占用中 {{frozen}}</text>
  </view>

  <view class="note-box">申请成功后将占用 {{item.coinValue}} 公益积分，完成接漂时才从总记录值中扣除；同时未收货最多 5 单，请先完成在途漂流。</view>

  <view class="btn-accent" bindtap="confirm">确认申请</view>
</view>
