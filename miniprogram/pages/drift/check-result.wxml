<view class="page result-page">
  <view class="icon {{passed ? 'ok' : 'fail'}}">{{passed ? '✓' : '✗'}}</view>
  <view class="result-title">{{passed ? '已加入漂流池' : '检测未通过'}}</view>
  <view class="result-sub muted">{{passed ? '系统检测全部通过，无需人工审核' : '请根据原因修改后重试'}}</view>

  <view class="card checks" wx:if="{{passed}}">
    <view wx:for="{{checks}}" wx:key="name" class="check-item">✓ {{item.name}}</view>
    <view wx:if="{{coinValue > 0}}" class="hero-coin mini">
      <view class="hero-label">预获得公益积分（收货后到账）</view>
      <view class="hero-num">+{{coinValue}}</view>
    </view>
    <view wx:else class="hero-coin mini">
      <view class="hero-label">本次无流转积分</view>
      <view class="result-sub muted">完成赠书后不计入首次完成赠书奖励</view>
    </view>
  </view>

  <view class="card" wx:else>
    <view wx:for="{{reasons}}" wx:key="code" class="reason">· {{item.message}}</view>
    <view class="btn-line" bindtap="appeal" style="margin-top:24rpx">提交申诉</view>
  </view>

  <view wx:if="{{passed}}" class="btn-line subscribe-btn" bindtap="enableSubscribeNotify">接漂时微信提醒我</view>
  <view wx:if="{{passed}}" class="subscribe-hint muted">可选；拒绝不影响漂流与发货</view>

  <view class="btn-primary" bindtap="goNext">{{continueScan && passed ? '继续扫码上漂' : (passed ? '查看漂流广场' : '返回修改')}}</view>
  <view wx:if="{{continueScan && passed}}" class="btn-line pool-link" bindtap="goPoolFromScan">查看漂流广场</view>
</view>
