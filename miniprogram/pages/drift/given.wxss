.page { padding: 24rpx; }
.reminder-card {
  background: #fff7e6;
  border: 1rpx solid #ffe0a3;
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.reminder-title {
  color: #9A5B00;
  font-size: 30rpx;
  font-weight: 800;
}
.reminder-sub {
  margin-top: 8rpx;
  color: #9A6A2C;
  font-size: 24rpx;
  line-height: 1.5;
}
.subscribe-link {
  margin-top: 16rpx;
  color: #0C7A4B;
  font-size: 24rpx;
  font-weight: 700;
}
.order-card .row { display: flex; gap: 16rpx; margin-top: 12rpx; }
.progress-box {
  margin-top: 18rpx;
  padding: 18rpx;
  background: #f6faf7;
  border-radius: 20rpx;
}
.progress-text {
  color: #15211B;
  font-size: 26rpx;
  font-weight: 700;
}
.progress-hint {
  margin-top: 6rpx;
  color: #6A7B72;
  font-size: 23rpx;
}
.order-action {
  margin-top: 16rpx;
  min-height: 72rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
}

.order-action.primary {
  color: #fff;
  background: #2FBE77;
}

.order-action.secondary {
  color: #159E63;
  background: #EAFBF2;
}

.order-action.danger {
  color: #C0442E;
  background: #FFF1ED;
}
.bundle-badge {
  margin-left: 12rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #EAFBF2;
  color: #0C7A4B;
  font-size: 22rpx;
  font-weight: 600;
}
.bundle-row { margin-top: 12rpx; }
.receiver-line { margin-top: 12rpx; }

.logistics { margin-top: 12rpx; font-size: 24rpx; color: #2FBE77; }
