.row { display: flex; gap: 20rpx; align-items: center; }
.book-card .title { font-size: 32rpx; font-weight: 700; color: #15211B; }
.book-card .receiver { margin-top: 8rpx; font-size: 24rpx; }
.deadline-card {
  background: #fff7e6;
  border: 1rpx solid #ffe0a3;
  border-radius: 28rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}
.deadline-title { color: #9A5B00; font-size: 28rpx; font-weight: 700; }
.deadline-sub { margin-top: 8rpx; color: #9A6A2C; font-size: 24rpx; }
.section-label { font-size: 28rpx; font-weight: 700; color: #15211B; margin-bottom: 16rpx; }
.address-name { font-size: 30rpx; font-weight: 600; color: #15211B; }
.address-phone { margin-top: 8rpx; font-size: 28rpx; color: #46564e; }
.address-detail { margin-top: 8rpx; font-size: 28rpx; color: #46564e; line-height: 1.5; }
.privacy-note { margin-top: 16rpx; font-size: 22rpx; color: #9aa8a0; }
.action-row { display: flex; gap: 16rpx; margin-top: 24rpx; }
.action-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 12rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-sizing: border-box;
}
.field-label { font-size: 24rpx; color: #9aa8a0; margin: 24rpx 0 12rpx; font-weight: 500; }
.picker-line,
.tracking-input {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf1ee;
  font-size: 28rpx;
  color: #15211B;
}
.tracking-error { margin-top: 12rpx; font-size: 24rpx; color: #C0442E; line-height: 1.5; }
.tracking-hint { margin-top: 16rpx; font-size: 24rpx; color: #9aa8a0; line-height: 1.5; }
.submit-btn { margin-top: 8rpx; }
.submit-btn[disabled] {
  background: #c8d9cf;
  color: #fff;
  box-shadow: none;
}
.cancel-btn { margin-top: 16rpx; }
