<view class="page"><view class="card"><view class="label">申诉原因</view><textarea maxlength="500" value="{{reason}}" bindinput="inputReason" placeholder="请客观描述问题"/><button class="btn-ghost" bindtap="chooseEvidence">上传举证（最多 3 张）</button><view class="muted">已上传 {{images.length}} 张</view></view><button class="btn-primary" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submit">提交申诉</button></view>
