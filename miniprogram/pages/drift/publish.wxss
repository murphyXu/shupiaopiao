.page { padding: 24rpx 24rpx 60rpx; }
.row { display: flex; gap: 20rpx; align-items: center; }
.info { flex: 1; min-width: 0; }
.change-book {
  flex-shrink: 0;
  color: #2FBE77;
  font-size: 24rpx;
  font-weight: 700;
}
.book-picker {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}
.book-option {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  border: 1rpx solid #eef3ef;
  border-radius: 22rpx;
  background: #fbfdfb;
}
.picker-cover {
  flex-shrink: 0;
  width: 96rpx;
  height: 136rpx;
  border-radius: 12rpx;
  background: #fff;
}
.picker-info {
  flex: 1;
  min-width: 0;
}
.picker-title {
  font-size: 28rpx;
  color: #15211B;
  font-weight: 700;
  line-height: 1.35;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.picker-meta {
  margin-top: 10rpx;
  color: #6A7B72;
  font-size: 23rpx;
}
.empty-box {
  color: #6A7B72;
  text-align: center;
  padding: 28rpx 0 8rpx;
}
.empty-box .small {
  margin: 20rpx auto 0;
  width: 220rpx;
  padding: 14rpx 0;
  font-size: 24rpx;
}
.disabled-card {
  opacity: 0.72;
}
.image-slots {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.chips {
  display: grid;
  gap: 10rpx;
  padding-bottom: 0;
}

.condition-chips {
  grid-template-columns: repeat(5, 1fr);
}

.issue-chips {
  grid-template-columns: repeat(3, 1fr);
}

.chips .chip {
  margin-bottom: 0;
  min-width: 0;
  padding: 13rpx 4rpx;
  text-align: center;
  white-space: nowrap;
  font-size: 22rpx;
  line-height: 1.2;
}

.image-slot {
  border: 1rpx solid #eef3ef;
  border-radius: 18rpx;
  padding: 10rpx;
  background: #fbfdfb;
  min-width: 0;
}
.slot-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 4rpx;
  margin-bottom: 8rpx;
}
.slot-label {
  font-size: 23rpx;
  color: #15211B;
  font-weight: 700;
  white-space: nowrap;
}
.slot-required {
  color: #ff4d4f;
  font-size: 19rpx;
  white-space: nowrap;
}

.slot-required.optional {
  color: #9aa8a0;
}
.slot-image, .slot-add {
  width: 100%;
  height: 128rpx;
  border-radius: 14rpx;
  position: relative;
  overflow: hidden;
  background: #fff;
}
.slot-image image {
  width: 100%;
  height: 100%;
  background: #fff;
}
.slot-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f2f4f8;
  border: 1rpx dashed #d6dbe2;
  color: #9aa8a0;
}
.slot-plus {
  font-size: 34rpx;
  line-height: 1;
}
.slot-hint {
  margin-top: 8rpx;
  padding: 0 4rpx;
  font-size: 20rpx;
  line-height: 1.25;
  text-align: center;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.del { position: absolute; top: -10rpx; right: -10rpx; background: #ff4d4f; color: #fff; width: 36rpx; height: 36rpx; border-radius: 50%; text-align: center; line-height: 36rpx; font-size: 24rpx; }
.sub-label {
  margin: 16rpx 0 12rpx;
  color: #46564e;
  font-size: 25rpx;
  font-weight: 700;
}
.price-line {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  color: #46564e;
  font-size: 24rpx;
  margin-bottom: 18rpx;
}
.price-warning {
  color: #ff4d4f;
  background: #fff4f4;
  border-radius: 18rpx;
  padding: 18rpx;
  font-size: 24rpx;
  margin-bottom: 18rpx;
}
.coin-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 1rpx solid #d6dbe2;
  border-radius: 18rpx;
  padding: 0 18rpx;
  background: #fff;
}
.coin-input {
  flex: 1;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #0C7A4B;
}
.coin-unit {
  color: #46564e;
  font-size: 26rpx;
}
.coin-hint {
  margin-top: 12rpx;
  color: #9aa8a0;
  font-size: 23rpx;
  line-height: 1.45;
}
.coin-stepper-row {
  margin-top: 8rpx;
}
.coin-stepper-label {
  color: #46564e;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}
.coin-stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}
.stepper-btn {
  width: 72rpx;
  height: 72rpx;
  margin: 0;
  padding: 0;
  line-height: 72rpx;
  border-radius: 18rpx;
  background: #EAFBF2;
  color: #0C7A4B;
  font-size: 40rpx;
  font-weight: 700;
}
.stepper-btn::after {
  border: 0;
}
.stepper-btn[disabled] {
  opacity: 0.45;
  color: #9aa8a0;
  background: #f2f4f8;
}
.coin-stepper-value {
  min-width: 160rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
  color: #0C7A4B;
}
.publish-submit {
  width: 100%;
  margin: 0;
  line-height: 1.4;
  border: 0;
}
.publish-submit::after {
  border: 0;
}
.publish-submit[disabled] {
  opacity: 0.72;
  color: #fff;
  background: #8fd9b5;
}
.identity-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.identity-option {
  border: 1rpx solid #eef3ef;
  border-radius: 22rpx;
  padding: 20rpx;
  background: #fbfdfb;
}
.identity-option.active {
  border-color: #2FBE77;
  background: #EAFBF2;
}
.identity-title {
  color: #15211B;
  font-size: 26rpx;
  font-weight: 800;
}
.identity-desc {
  margin-top: 8rpx;
  color: #6A7B72;
  font-size: 22rpx;
  line-height: 1.4;
}
.ship-region-note,
.ship-region-line {
  margin-top: 16rpx;
  font-size: 23rpx;
  line-height: 1.45;
}
textarea { width: 100%; min-height: 100rpx; border: 1rpx solid #d6dbe2; border-radius: 12rpx; padding: 16rpx; box-sizing: border-box; }
