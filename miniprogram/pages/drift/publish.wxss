.page { padding: 24rpx 24rpx 60rpx; }
.row { display: flex; gap: 20rpx; align-items: center; }
.info { flex: 1; min-width: 0; }
.change-book {
  flex-shrink: 0;
  color: #2FBE77;
  font-size: 24rpx;
  font-weight: 700;
}
.book-picker {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}
.book-option {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  border: 1rpx solid #eef3ef;
  border-radius: 22rpx;
  background: #fbfdfb;
}
.book-option.selected {
  border-color: #2FBE77;
  background: #EAFBF2;
}
.picker-check {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 1rpx solid #d6dbe2;
  color: #fff;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  align-self: center;
}
.picker-check.checked {
  border-color: #2FBE77;
  background: #2FBE77;
}
.selection-note,
.batch-clear {
  margin-top: 16rpx;
}
.batch-selected-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.batch-selected-item {
  display: flex;
  gap: 18rpx;
  align-items: center;
}
.batch-book-settings {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.batch-book-card .batch-book-head {
  display: flex;
  gap: 18rpx;
  align-items: center;
  margin-bottom: 20rpx;
}
.batch-summary-item {
  padding: 10rpx 0 6rpx;
  border-bottom: 1rpx dashed #eef2ef;
}
.batch-summary-item:last-child {
  border-bottom: none;
}
.summary-sub {
  font-size: 22rpx;
  line-height: 1.4;
  padding-bottom: 8rpx;
}
.picker-cover {
  flex-shrink: 0;
  width: 96rpx;
  height: 136rpx;
  border-radius: 12rpx;
  background: #fff;
}
.picker-info {
  flex: 1;
  min-width: 0;
}
.picker-title {
  font-size: 28rpx;
  color: #15211B;
  font-weight: 700;
  line-height: 1.35;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.picker-meta {
  margin-top: 10rpx;
  color: #6A7B72;
  font-size: 23rpx;
}
.picker-price-warning {
  margin-top: 8rpx;
  color: #ff4d4f;
  font-size: 22rpx;
  line-height: 1.35;
}
.picker-meta-hint {
  margin-top: 8rpx;
  color: #b8860b;
  font-size: 22rpx;
  line-height: 1.35;
}
.set-confirm-card.attention {
  border: 1rpx solid #f5a623;
  background: #fffbf0;
}
.set-confirm-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}
.set-confirm-header .label {
  margin-bottom: 0;
}
.set-confirm-pending {
  flex-shrink: 0;
  color: #ff4d4f;
  font-size: 22rpx;
  font-weight: 700;
}
.set-confirm-badge {
  margin-top: 8rpx;
  color: #b8860b;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.35;
}
.set-confirm-item {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed #eef2ef;
}
.set-confirm-item:first-of-type {
  margin-top: 16rpx;
  padding-top: 0;
  border-top: none;
}
.set-confirm-reason {
  margin-top: 6rpx;
  font-size: 22rpx;
}
.picker-edit-link {
  margin-top: 8rpx;
  color: #2FBE77;
  font-size: 22rpx;
  font-weight: 700;
}
.inline-link {
  color: #2FBE77;
  font-weight: 700;
  margin-left: 8rpx;
}
.empty-box {
  color: #6A7B72;
  text-align: center;
  padding: 28rpx 0 8rpx;
}
.empty-box .small {
  margin: 20rpx auto 0;
  width: 220rpx;
  padding: 14rpx 0;
  font-size: 24rpx;
}
.disabled-card {
  opacity: 0.72;
}
.image-slots {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.chips {
  display: grid;
  gap: 10rpx;
  padding-bottom: 0;
}

.condition-chips {
  grid-template-columns: repeat(5, 1fr);
}

.issue-chips {
  grid-template-columns: repeat(3, 1fr);
}

.chips .chip {
  margin-bottom: 0;
  min-width: 0;
  padding: 13rpx 4rpx;
  text-align: center;
  white-space: nowrap;
  font-size: 22rpx;
  line-height: 1.2;
}

.image-slot {
  border: 1rpx solid #eef3ef;
  border-radius: 18rpx;
  padding: 10rpx;
  background: #fbfdfb;
  min-width: 0;
}
.slot-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 4rpx;
  margin-bottom: 8rpx;
}
.slot-label {
  font-size: 23rpx;
  color: #15211B;
  font-weight: 700;
  white-space: nowrap;
}
.slot-required {
  color: #ff4d4f;
  font-size: 19rpx;
  white-space: nowrap;
}

.slot-required.optional {
  color: #9aa8a0;
}
.slot-image, .slot-add {
  width: 100%;
  height: 128rpx;
  border-radius: 14rpx;
  position: relative;
  overflow: hidden;
  background: #fff;
}
.slot-image image {
  width: 100%;
  height: 100%;
  background: #fff;
}
.slot-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f2f4f8;
  border: 1rpx dashed #d6dbe2;
  color: #9aa8a0;
}
.slot-plus {
  font-size: 34rpx;
  line-height: 1;
}
.slot-hint {
  margin-top: 8rpx;
  padding: 0 4rpx;
  font-size: 20rpx;
  line-height: 1.25;
  text-align: center;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.del { position: absolute; top: -10rpx; right: -10rpx; background: #ff4d4f; color: #fff; width: 36rpx; height: 36rpx; border-radius: 50%; text-align: center; line-height: 36rpx; font-size: 24rpx; }
.sub-label {
  margin: 16rpx 0 12rpx;
  color: #46564e;
  font-size: 25rpx;
  font-weight: 700;
}
.price-line {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  color: #46564e;
  font-size: 24rpx;
  margin-bottom: 18rpx;
}
.price-warning {
  color: #ff4d4f;
  background: #fff4f4;
  border-radius: 18rpx;
  padding: 18rpx;
  font-size: 24rpx;
  margin-bottom: 18rpx;
}
.coin-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 1rpx solid #d6dbe2;
  border-radius: 18rpx;
  padding: 0 18rpx;
  background: #fff;
}
.coin-input {
  flex: 1;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #0C7A4B;
}
.coin-unit {
  color: #46564e;
  font-size: 26rpx;
}
.coin-hint {
  margin-top: 12rpx;
  color: #9aa8a0;
  font-size: 23rpx;
  line-height: 1.45;
}
.coin-stepper-row {
  margin-top: 8rpx;
}
.coin-stepper-label {
  color: #46564e;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}
.coin-stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}
.stepper-btn {
  width: 72rpx;
  height: 72rpx;
  margin: 0;
  padding: 0;
  line-height: 72rpx;
  border-radius: 18rpx;
  background: #EAFBF2;
  color: #0C7A4B;
  font-size: 40rpx;
  font-weight: 700;
}
.stepper-btn::after {
  border: 0;
}
.stepper-btn[disabled] {
  opacity: 0.45;
  color: #9aa8a0;
  background: #f2f4f8;
}
.coin-stepper-value {
  min-width: 160rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
  color: #0C7A4B;
}
.publish-submit {
  width: 100%;
  margin: 0;
  line-height: 1.4;
  border: 0;
}
.publish-submit::after {
  border: 0;
}
.publish-submit[disabled] {
  opacity: 0.72;
  color: #fff;
  background: #8fd9b5;
}
.identity-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.identity-option {
  border: 1rpx solid #eef3ef;
  border-radius: 22rpx;
  padding: 20rpx;
  background: #fbfdfb;
}
.identity-option.active {
  border-color: #2FBE77;
  background: #EAFBF2;
}
.identity-title {
  color: #15211B;
  font-size: 26rpx;
  font-weight: 800;
}
.identity-desc {
  margin-top: 8rpx;
  color: #6A7B72;
  font-size: 22rpx;
  line-height: 1.4;
}
.ship-region-note,
.ship-region-line {
  margin-top: 16rpx;
  font-size: 23rpx;
  line-height: 1.45;
}
textarea { width: 100%; min-height: 100rpx; border: 1rpx solid #d6dbe2; border-radius: 12rpx; padding: 16rpx; box-sizing: border-box; }

.publish-stepped {
  padding-bottom: 160rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.stepper {
  display: flex;
  align-items: center;
  padding: 8rpx 8rpx 24rpx;
}
.stp {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}
.stp-dot {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #e3ede7;
  color: #8a988f;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}
.stp.on .stp-dot { background: #2FBE77; color: #fff; }
.stp.done .stp-dot { background: #EAFBF2; color: #0C7A4B; }
.stp-label { font-size: 22rpx; color: #7b8a82; }
.stp.on .stp-label { color: #0C7A4B; font-weight: 700; }
.stp-line {
  flex: 1;
  height: 3rpx;
  background: #e3ede7;
  margin: 0 6rpx;
  position: relative;
  top: -16rpx;
}
.stp-line.done { background: #2FBE77; }

.step-body { min-height: 200rpx; }

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx dashed #eef2ef;
  font-size: 26rpx;
}
.summary-row:last-child { border-bottom: none; }
.summary-row .sk { color: #7b8a82; flex-shrink: 0; }
.summary-row .sv { color: #15211B; font-weight: 700; text-align: right; }
.summary-row .sv.hl { color: #0C7A4B; }

.step-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eef2ef;
  z-index: 50;
}
.step-nav-btn {
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
  margin: 0;
}
.step-nav-btn::after { border: 0; }
.step-nav-btn.ghost {
  flex: 1;
  background: #f0f5f1;
  color: #46564e;
}
.step-nav-btn.primary {
  flex: 2;
  background: #2FBE77;
  color: #fff;
}
.step-nav-btn.primary[disabled] {
  opacity: 0.72;
  color: #fff;
  background: #8fd9b5;
}
