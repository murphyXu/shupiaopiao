@import "./publish.wxss";

.scan-card {
  padding-bottom: 8rpx;
}
.scan-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}
.scan-tip {
  margin-top: 8rpx;
  font-size: 23rpx;
}
.scan-btn {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}
.session-note {
  margin-top: 16rpx;
  font-size: 23rpx;
}
.lookup-error {
  margin-top: 12rpx;
  color: #ff4d4f;
  font-size: 24rpx;
}
.empty-scan {
  text-align: center;
  padding: 36rpx 24rpx;
}
.scan-start {
  margin-top: 24rpx;
}
.isbn-line {
  margin-top: 8rpx;
  font-size: 22rpx;
}
.finish-link {
  margin: 0 0 16rpx;
  text-align: right;
  color: #0C7A4B;
  font-size: 26rpx;
  font-weight: 600;
}
.continuous-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: #f6fbf8;
  border-radius: 28rpx;
  padding: 20rpx 24rpx;
}
.switch-dot {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 4rpx solid #c9d8d0;
  box-sizing: border-box;
  flex-shrink: 0;
}
.switch-dot.active {
  border-color: #2FBE77;
  background: #2FBE77;
  box-shadow: inset 0 0 0 8rpx #fff;
}
.continuous-title {
  font-size: 28rpx;
  color: #15211B;
  font-weight: 700;
}
.batch-message {
  margin-top: 16rpx;
  color: #0C7A4B;
  background: #EAFBF2;
  border-radius: 22rpx;
  padding: 12rpx 18rpx;
  font-size: 24rpx;
}
