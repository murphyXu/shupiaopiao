.page { padding: 24rpx 24rpx 60rpx; }
.result-page {
  text-align: center;
}
.icon {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  border-radius: 50%;
  margin: 24rpx auto;
  font-size: 56rpx;
  font-weight: 800;
}
.icon.ok {
  background: #EAFBF2;
  color: #0C7A4B;
}
.result-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #15211B;
}
.result-sub {
  margin: 12rpx 0 24rpx;
  font-size: 24rpx;
}
.batch-result-item {
  text-align: left;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eef3ef;
}
.batch-result-item:last-child {
  border-bottom: 0;
}
.batch-result-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #15211B;
}
.batch-result-status {
  margin-top: 8rpx;
  font-size: 23rpx;
}
.ok-text { color: #0C7A4B; }
.fail-text { color: #ff4d4f; }
.btn-primary,
.btn-line {
  margin-top: 24rpx;
}
