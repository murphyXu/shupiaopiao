/* 书漂漂 · 品牌视觉设计令牌 v3 */
/* 主绿 #34C77B / #2FBE77 | 深绿 #159E63 | 墨绿 #0C7A4B | 薄荷 #7BE2A8 | 浅绿底 #EAFBF2 */

.brand { color: #2FBE77; }
.accent { color: #0C7A4B; }
.muted { color: #9aa8a0; }
.text-ink { color: #15211B; }
.text-ink2 { color: #46564e; }

/* 页面容器（顶部安全区由各页 style 动态注入 px 值） */
.page {
  min-height: 100vh;
  padding: 0 44rpx 40rpx;
  box-sizing: border-box;
}

.page-tab {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.guest-login-btn {
  display: inline-block;
  margin-top: 24rpx;
  padding: 16rpx 48rpx;
  background: #2FBE77;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.page-header {
  padding: 8rpx 0 24rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #15211B;
  letter-spacing: 1rpx;
}

.page-sub {
  font-size: 24rpx;
  color: #9aa8a0;
  margin-top: 6rpx;
  font-weight: 400;
}

.card {
  background: #fff;
  border: 1rpx solid #eef3ef;
  border-radius: 36rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 20rpx 80rpx rgba(21, 158, 99, 0.08);
}

.chip {
  display: inline-block;
  font-size: 24rpx;
  padding: 14rpx 28rpx;
  border-radius: 40rpx;
  background: #f0f5f1;
  color: #46564e;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.chip.active {
  background: #2FBE77;
  color: #fff;
  border: none;
}

.badge {
  display: inline-block;
  font-size: 22rpx;
  background: #EAFBF2;
  color: #0C7A4B;
  padding: 6rpx 18rpx;
  border-radius: 16rpx;
  font-weight: 700;
}

.coin {
  display: inline-flex;
  align-items: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #0C7A4B;
  background: #EAFBF2;
  padding: 6rpx 18rpx;
  border-radius: 16rpx;
}

.pill {
  display: inline-block;
  font-size: 20rpx;
  color: #9aa8a0;
  background: #f2f5f3;
  padding: 6rpx 18rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.btn-primary {
  background: #2FBE77;
  color: #fff;
  text-align: center;
  padding: 30rpx;
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 40rpx rgba(47, 190, 119, 0.3);
}

.btn-accent,
.btn-deep {
  background: #0C7A4B;
  color: #fff;
  text-align: center;
  padding: 30rpx;
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 40rpx rgba(12, 122, 75, 0.3);
}

.btn-ghost,
.btn-line {
  background: #fff;
  color: #159E63;
  border: 2rpx solid #2FBE77;
  text-align: center;
  padding: 28rpx;
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: none;
}

.note-box,
.tip {
  font-size: 25rpx;
  color: #0C7A4B;
  background: #EAFBF2;
  border: 1rpx solid #cdeede;
  border-radius: 28rpx;
  padding: 24rpx 28rpx;
  line-height: 1.6;
}

.report-link {
  margin-top: 16rpx;
  color: #8a9690;
  font-size: 24rpx;
  text-align: right;
}

.empty {
  text-align: center;
  padding: 100rpx 40rpx;
  color: #9aa8a0;
  font-size: 28rpx;
}

.fab {
  position: fixed;
  right: 44rpx;
  bottom: 180rpx;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: #2FBE77;
  color: #fff;
  font-size: 56rpx;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 52rpx rgba(47, 190, 119, 0.45);
  z-index: 100;
}

.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28rpx;
}

.book-cover {
  width: 100%;
  height: 248rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #dff4e8, #c3ead4);
}

.book-cover-sm {
  width: 80rpx;
  height: 108rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #dff4e8, #c3ead4);
  flex-shrink: 0;
}

/* 统计块 */
.stat-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.stat-card {
  flex: 1;
  background: #EAFBF2;
  border-radius: 36rpx;
  padding: 28rpx 16rpx;
  text-align: center;
}

.stat-card .num {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #0C7A4B;
}

.stat-card .label {
  font-size: 22rpx;
  color: #159E63;
  margin-top: 4rpx;
}

/* 分段选择器 */
.seg-tabs {
  display: flex;
  gap: 12rpx;
  background: #f0f5f1;
  border-radius: 28rpx;
  padding: 8rpx;
  margin-bottom: 32rpx;
}

.seg-tab {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  padding: 16rpx 8rpx;
  border-radius: 20rpx;
  color: #9aa8a0;
  font-weight: 500;
}

.seg-tab.active {
  background: #fff;
  color: #159E63;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

/* 搜索框 */
.search-box {
  background: #f0f5f1;
  border-radius: 28rpx;
  padding: 24rpx 32rpx;
  color: #9aa8a0;
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.search-box input {
  width: 100%;
  font-size: 26rpx;
}

/* 公益积分英雄卡片 */
.hero-coin {
  background: linear-gradient(135deg, #34C77B, #159E63);
  border-radius: 44rpx;
  padding: 44rpx;
  color: #fff;
  box-shadow: 0 28rpx 60rpx rgba(21, 158, 99, 0.28);
}

.hero-coin .hero-label {
  font-size: 24rpx;
  opacity: 0.85;
}

.hero-coin .hero-num {
  font-size: 68rpx;
  font-weight: 700;
  margin-top: 4rpx;
  letter-spacing: 1rpx;
}

/* 菜单列表 */
.menu-list .menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 8rpx;
  border-bottom: 1rpx solid #eef3ef;
  font-size: 28rpx;
  color: #15211B;
}

.menu-list .menu-item:last-child {
  border-bottom: none;
}

.menu-list .menu-arrow {
  color: #9aa8a0;
}

/* 用户头像占位 */
.avatar-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7BE2A8, #2FBE77);
  flex-shrink: 0;
}

.avatar-circle.sm {
  width: 64rpx;
  height: 64rpx;
}

/* 订单卡片 */
.order-card {
  background: #fff;
  border: 1rpx solid #eef3ef;
  border-radius: 36rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.status-dot {
  font-size: 22rpx;
  font-weight: 600;
  color: #2FBE77;
  background: #EAFBF2;
  padding: 6rpx 20rpx;
  border-radius: 16rpx;
}

.field {
  background: #f7faf8;
  border: 1rpx solid #eef3ef;
  border-radius: 28rpx;
  padding: 26rpx 30rpx;
  font-size: 26rpx;
  color: #9aa8a0;
}

.label {
  font-size: 24rpx;
  color: #9aa8a0;
  margin: 32rpx 0 16rpx;
  font-weight: 500;
}
