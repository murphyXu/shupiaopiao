/* 书漂漂 · 品牌视觉设计令牌 v4（UI/UX 优化：字阶收敛 + 中性灰阶 + 绿色预算 + 触控规范） */
/* 主绿 #34C77B / #2FBE77 | 深绿 #159E63 | 墨绿 #0C7A4B | 薄荷 #7BE2A8 | 浅绿底 #EAFBF2 */

page {
  /* —— 品牌绿（仅用于主行动 + 公益积分） —— */
  --green: #2FBE77;
  --green-deep: #159E63;
  --green-ink: #0C7A4B;
  --mint: #EAFBF2;
  /* —— 中性灰阶（承载多数 UI） —— */
  --ink: #15211B;        /* 主文字 */
  --ink-2: #52605a;      /* 次文字 */
  --ink-3: #8a988f;      /* 辅助/占位 */
  --surface: #ffffff;    /* 卡片面 */
  --neutral: #f0f3f1;    /* 中性标签底 */
  --line: #e7eee9;       /* 分隔线 */
  /* —— 字阶（仅 5 级，下限 22rpx） —— */
  --fs-display: 48rpx;   /* 页标题 */
  --fs-title: 32rpx;     /* 卡片标题/书名 */
  --fs-body: 28rpx;      /* 正文/菜单 */
  --fs-caption: 24rpx;   /* 说明/副标题 */
  --fs-label: 22rpx;     /* 标签下限 */
  /* —— 圆角（3 档） —— */
  --r-card: 32rpx;
  --r-ctrl: 24rpx;
  --r-tag: 16rpx;
  /* —— 触控热区下限 —— */
  --hit: 80rpx;
  /* —— 统一轻阴影 —— */
  --shadow-card: 0 16rpx 48rpx rgba(21, 158, 99, 0.06);
}

.brand { color: #2FBE77; }
.accent { color: #0C7A4B; }
.muted { color: #9aa8a0; }
.text-ink { color: #15211B; }
.text-ink2 { color: #46564e; }

.share-cover-preload {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
}

/* 页面容器（顶部安全区由各页 style 动态注入 px 值） */
.page {
  min-height: 100vh;
  padding: 0 44rpx 40rpx;
  box-sizing: border-box;
}

.page-tab {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.sticky-search-filter {
  position: sticky;
  z-index: 150;
  box-sizing: border-box;
  margin: 0 -44rpx;
  padding: 0 44rpx 8rpx;
  background: #f4f8f5;
}

.sticky-search-filter .pool-search-box,
.sticky-search-filter .shelf-search {
  margin-bottom: 24rpx;
}

.sticky-search-filter .pool-filter-bar,
.sticky-search-filter .shelf-filter-bar {
  margin-bottom: 16rpx;
}

/* 分类筛选：单行等分展示，无需横滑 */
.pool-filter-bar,
.shelf-filter-bar {
  position: relative;
}

.filter-chips {
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  gap: 8rpx;
  width: 100%;
}

.filter-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-width: 0;
  height: 56rpx;
  padding: 0 4rpx;
  border-radius: 28rpx;
  background: #fff;
  color: #46564e;
  border: 1rpx solid #e6eee9;
  font-size: 22rpx;
  font-weight: 600;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.filter-chip.active {
  background: #2FBE77;
  color: #fff;
  border-color: #2FBE77;
  font-weight: 700;
}

.filter-chip.more {
  color: #0C7A4B;
  background: #f4fbf7;
  border-color: #dcefe4;
}

.filter-chip.more.active {
  background: #159E63;
  border-color: #159E63;
  color: #fff;
}

.chip-caret {
  flex-shrink: 0;
  margin-left: 2rpx;
  font-size: 16rpx;
}

.guest-login-btn {
  display: inline-block;
  margin-top: 24rpx;
  padding: 16rpx 48rpx;
  background: #2FBE77;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.page-header {
  padding: 8rpx 0 24rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #15211B;
  letter-spacing: 1rpx;
}

.page-sub {
  font-size: 24rpx;
  color: #9aa8a0;
  margin-top: 6rpx;
  font-weight: 400;
}

.card {
  background: #fff;
  border: 1rpx solid #eef3ef;
  border-radius: 36rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.chip {
  display: inline-block;
  font-size: 24rpx;
  padding: 14rpx 28rpx;
  border-radius: 40rpx;
  background: #f0f5f1;
  color: #46564e;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.chip.active {
  background: #2FBE77;
  color: #fff;
  border: none;
}

.badge {
  display: inline-block;
  font-size: 22rpx;
  background: #EAFBF2;
  color: #0C7A4B;
  padding: 6rpx 18rpx;
  border-radius: 16rpx;
  font-weight: 700;
}

.coin {
  display: inline-flex;
  align-items: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #0C7A4B;
  background: #EAFBF2;
  padding: 6rpx 18rpx;
  border-radius: 16rpx;
}

.pill {
  display: inline-block;
  font-size: 20rpx;
  color: #9aa8a0;
  background: #f2f5f3;
  padding: 6rpx 18rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.btn-primary {
  background: #2FBE77;
  color: #fff;
  text-align: center;
  padding: 30rpx;
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 40rpx rgba(47, 190, 119, 0.3);
}

.btn-accent,
.btn-deep {
  background: #0C7A4B;
  color: #fff;
  text-align: center;
  padding: 30rpx;
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 40rpx rgba(12, 122, 75, 0.3);
}

.btn-ghost,
.btn-line {
  background: #fff;
  color: #159E63;
  border: 2rpx solid #2FBE77;
  text-align: center;
  padding: 28rpx;
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: none;
}

.note-box,
.tip {
  font-size: 25rpx;
  color: #0C7A4B;
  background: #EAFBF2;
  border: 1rpx solid #cdeede;
  border-radius: 28rpx;
  padding: 24rpx 28rpx;
  line-height: 1.6;
}

.report-link {
  margin-top: 16rpx;
  color: #8a9690;
  font-size: 24rpx;
  text-align: right;
}

.empty {
  text-align: center;
  padding: 100rpx 40rpx;
  color: #9aa8a0;
  font-size: 28rpx;
}

.fab {
  position: fixed;
  right: 44rpx;
  bottom: 180rpx;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: #2FBE77;
  color: #fff;
  font-size: 56rpx;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 52rpx rgba(47, 190, 119, 0.45);
  z-index: 100;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 28rpx;
}

/* Two-column book list card — shared by pool and shelf */
.grid-book-card {
  min-width: 0;
  overflow: hidden;
  box-sizing: border-box;
  background: #fff;
  border: 1rpx solid #eef3ef;
  border-radius: 36rpx;
  padding: 20rpx;
  box-shadow: 0 12rpx 40rpx rgba(21, 158, 99, 0.06);
}

.grid-book-cover-frame {
  width: 100%;
  min-width: 0;
  height: 260rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.grid-book-cover-frame .book-cover {
  width: 100%;
  height: 100%;
  background: transparent;
}

.grid-book-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 12rpx;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #15211B;
}

.grid-book-subline {
  font-size: 22rpx;
  color: #8a988f;
  margin-top: 12rpx;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.grid-book-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  min-width: 0;
}

.grid-book-meta .coin {
  flex: 1 1 auto;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.grid-book-meta .pill {
  flex-shrink: 0;
  max-width: 46%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-cover {
  width: 100%;
  height: 248rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #dff4e8, #c3ead4);
}

.book-cover-sm {
  width: 80rpx;
  height: 108rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #dff4e8, #c3ead4);
  flex-shrink: 0;
}

/* 统计块 */
.stat-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.stat-card {
  flex: 1;
  background: #EAFBF2;
  border-radius: 36rpx;
  padding: 28rpx 16rpx;
  text-align: center;
}

.stat-card .num {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #0C7A4B;
}

.stat-card .label {
  font-size: 22rpx;
  color: #159E63;
  margin-top: 4rpx;
}

/* 分段选择器 */
.seg-tabs {
  display: flex;
  gap: 12rpx;
  background: #f0f5f1;
  border-radius: 28rpx;
  padding: 8rpx;
  margin-bottom: 32rpx;
}

.seg-tab {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  padding: 16rpx 8rpx;
  border-radius: 20rpx;
  color: #9aa8a0;
  font-weight: 500;
}

.seg-tab.active {
  background: #fff;
  color: #159E63;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

/* 搜索框 */
.search-box {
  background: #f0f5f1;
  border-radius: 28rpx;
  padding: 24rpx 32rpx;
  color: #9aa8a0;
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.search-box input {
  width: 100%;
  font-size: 26rpx;
}

/* 公益积分英雄卡片 */
.hero-coin {
  background: linear-gradient(135deg, #34C77B, #159E63);
  border-radius: 44rpx;
  padding: 44rpx;
  color: #fff;
  box-shadow: 0 28rpx 60rpx rgba(21, 158, 99, 0.28);
}

.hero-coin .hero-label {
  font-size: 24rpx;
  opacity: 0.85;
}

.hero-coin .hero-num {
  font-size: 68rpx;
  font-weight: 700;
  margin-top: 4rpx;
  letter-spacing: 1rpx;
}

/* 菜单列表 */
.menu-list .menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 8rpx;
  border-bottom: 1rpx solid #eef3ef;
  font-size: 28rpx;
  color: #15211B;
}

.menu-list .menu-item:last-child {
  border-bottom: none;
}

.menu-list .menu-arrow {
  color: #9aa8a0;
}

/* 用户头像占位 */
.avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #fff;
  border: 1rpx solid #eef3ef;
  box-sizing: border-box;
}

.avatar-placeholder.sm {
  width: 64rpx;
  height: 64rpx;
}

.avatar-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7BE2A8, #2FBE77);
  flex-shrink: 0;
}

.avatar-circle.sm {
  width: 64rpx;
  height: 64rpx;
}

/* 订单卡片 */
.order-card {
  background: #fff;
  border: 1rpx solid #eef3ef;
  border-radius: 36rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.order-meta {
  font-size: 22rpx;
  color: #8a988f;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.status-dot {
  font-size: 22rpx;
  font-weight: 600;
  color: #2FBE77;
  background: #EAFBF2;
  padding: 6rpx 20rpx;
  border-radius: 16rpx;
}

.field {
  background: #f7faf8;
  border: 1rpx solid #eef3ef;
  border-radius: 28rpx;
  padding: 26rpx 30rpx;
  font-size: 26rpx;
  color: #9aa8a0;
}

.label {
  font-size: 24rpx;
  color: #9aa8a0;
  margin: 32rpx 0 16rpx;
  font-weight: 500;
}

.form-label {
  font-size: 26rpx;
  color: #7b8a82;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.form-field + .form-field {
  margin-top: 24rpx;
}

.form-control {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  box-sizing: border-box;
  border: 1rpx solid #dbe7df;
  border-radius: 20rpx;
  background: #f8fbf9;
  padding: 0 22rpx;
  font-size: 28rpx;
  line-height: 88rpx;
  color: #15211B;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
  border: 1rpx solid #dbe7df;
  border-radius: 20rpx;
  background: #f8fbf9;
  padding: 18rpx 22rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #15211B;
}

.status-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.status-tabs {
  display: inline-flex;
  gap: 14rpx;
  min-width: 100%;
}

.status-tab {
  display: inline-flex;
  align-items: center;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 30rpx;
  background: #fff;
  color: #46564e;
  border: 1rpx solid #e6eee9;
  font-size: 24rpx;
  font-weight: 600;
}

.status-tab.active {
  background: #2FBE77;
  color: #fff;
  border-color: #2FBE77;
}

.tab-count {
  margin-left: 8rpx;
  font-size: 22rpx;
  opacity: 0.9;
}
