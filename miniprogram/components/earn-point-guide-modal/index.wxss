.earn-guide-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
  background: rgba(21, 33, 27, 0.42);
}

.earn-guide-dialog {
  width: 100%;
  max-height: 82vh;
  overflow-y: auto;
  box-sizing: border-box;
  padding: 42rpx 36rpx 34rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 28rpx 80rpx rgba(21, 33, 27, 0.22);
}

.earn-guide-title {
  color: #15211B;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.3;
}

.earn-guide-subtitle {
  margin-top: 10rpx;
  color: #7b8a82;
  font-size: 24rpx;
  line-height: 1.5;
}

.earn-guide-sections {
  margin-top: 30rpx;
}

.earn-guide-section {
  padding: 24rpx 24rpx 22rpx;
  border: 1rpx solid #dceee5;
  border-radius: 20rpx;
  background: #f7fcf9;
}

.earn-guide-section + .earn-guide-section {
  margin-top: 18rpx;
}

.earn-guide-section-title {
  color: #0C7A4B;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.35;
}

.earn-guide-line {
  margin-top: 12rpx;
  color: #405449;
  font-size: 25rpx;
  line-height: 1.55;
}

.earn-guide-line::before {
  content: "";
  display: inline-block;
  width: 8rpx;
  height: 8rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #2FBE77;
  vertical-align: 4rpx;
}

.earn-guide-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 32rpx;
}

.earn-guide-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  border-radius: 22rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.earn-guide-btn.secondary {
  background: #edf5f0;
  color: #52675c;
}

.earn-guide-btn.primary {
  background: #2FBE77;
  color: #fff;
}
