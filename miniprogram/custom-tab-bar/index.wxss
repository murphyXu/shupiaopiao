.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 12rpx 16rpx calc(12rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-top: 1rpx solid rgba(238, 243, 239, 0.9);
  box-shadow: 0 -8rpx 32rpx rgba(21, 158, 99, 0.06);
  z-index: 9999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.tab-icon-wrap {
  position: relative;
  width: 48rpx;
  height: 48rpx;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
}

.tab-badge {
  position: absolute;
  top: -10rpx;
  right: -18rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 6rpx;
  border-radius: 14rpx;
  background: #2FBE77;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 28rpx;
  text-align: center;
  box-sizing: border-box;
  border: 2rpx solid #fff;
}

.tab-text {
  font-size: 22rpx;
  color: #b3c0b8;
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: #2FBE77;
  font-weight: 600;
}
